{
  "$schema": "https://raw.githubusercontent.com/goalie-app/goalie/main/schema.json",
  "version": "1.0",
  "project": {
    "name": "Agentic Flow - Circle Governance",
    "description": "Holacracy-inspired circle-based continuous improvement tracking",
    "repository": "agentic-flow",
    "created": "2025-12-01"
  },
  "circles": [
    {
      "id": "analyst",
      "name": "Analyst Circle",
      "lead": "data-analyst-agent",
      "purpose": "Provide data-driven insights and strategic analysis for decision-making",
      "domains": [
        "Market analysis and trend identification",
        "Performance metrics and KPI tracking",
        "Competitive intelligence gathering",
        "Risk assessment and mitigation planning",
        "Financial modeling and forecasting"
      ],
      "standup": {
        "frequency": "weekly",
        "day": "monday",
        "time": "09:00",
        "timezone": "UTC"
      },
      "retrospective": {
        "frequency": "monthly",
        "week": "first",
        "day": "friday",
        "time": "14:00",
        "timezone": "UTC"
      },
      "objectives": [
        {
          "id": "analyst-001",
          "title": "Establish baseline metrics dashboard",
          "status": "in_progress",
          "priority": "high",
          "deadline": "2025-12-08",
          "keyResults": [
            "CI/CD success rate tracked",
            "Deployment frequency measured",
            "Code coverage baselined",
            "Security vulnerability count established"
          ]
        },
        {
          "id": "analyst-002",
          "title": "Dependency analysis and optimization",
          "status": "planned",
          "priority": "medium",
          "deadline": "2025-12-15",
          "keyResults": [
            "Dependency graph visualized",
            "Update lag times measured",
            "Cost optimization opportunities identified"
          ]
        }
      ]
    },
    {
      "id": "assessor",
      "name": "Assessor Circle",
      "lead": "quality-assurance-agent",
      "purpose": "Evaluate quality, performance, and compliance across all systems",
      "domains": [
        "Code quality assessment and review",
        "Security audit and vulnerability scanning",
        "Performance benchmarking and optimization",
        "Compliance validation (PCI, SOC2, regulatory)",
        "Quality gate enforcement"
      ],
      "standup": {
        "frequency": "weekly",
        "day": "tuesday",
        "time": "10:00",
        "timezone": "UTC"
      },
      "retrospective": {
        "frequency": "monthly",
        "week": "first",
        "day": "friday",
        "time": "15:00",
        "timezone": "UTC"
      },
      "objectives": [
        {
          "id": "assessor-001",
          "title": "CI/CD quality gates validation",
          "status": "in_progress",
          "priority": "high",
          "deadline": "2025-12-08",
          "keyResults": [
            "All quality gates documented",
            "Pass/fail criteria validated",
            "Test coverage meets 90% target",
            "Security scanning complete"
          ]
        },
        {
          "id": "assessor-002",
          "title": "Security scan review and enhancement",
          "status": "planned",
          "priority": "high",
          "deadline": "2025-12-15",
          "keyResults": [
            "SAST tool integrated (Snyk/Semgrep)",
            "Container scanning enabled (Trivy)",
            "IaC security validated (tfsec/checkov)",
            "Zero critical vulnerabilities"
          ]
        }
      ]
    },
    {
      "id": "innovator",
      "name": "Innovator Circle",
      "lead": "research-development-agent",
      "purpose": "Drive continuous improvement through experimentation and R&D",
      "domains": [
        "Emerging technology evaluation and POCs",
        "Process improvement initiatives",
        "Tool and framework evaluation",
        "Architectural innovation and refactoring",
        "AI/ML model exploration and integration"
      ],
      "standup": {
        "frequency": "weekly",
        "day": "wednesday",
        "time": "11:00",
        "timezone": "UTC"
      },
      "retrospective": {
        "frequency": "monthly",
        "week": "first",
        "day": "friday",
        "time": "16:00",
        "timezone": "UTC"
      },
      "objectives": [
        {
          "id": "innovator-001",
          "title": "Rust-centricity evaluation",
          "status": "in_progress",
          "priority": "high",
          "deadline": "2025-12-15",
          "keyResults": [
            "Rust vs PyTorch comparison documented",
            "Performance benchmarks completed",
            "Migration feasibility assessed",
            "Recommendation presented"
          ]
        },
        {
          "id": "innovator-002",
          "title": "Agent Booster optimization",
          "status": "planned",
          "priority": "medium",
          "deadline": "2025-12-22",
          "keyResults": [
            "352x speedup validated",
            "WASM bundle size optimized",
            "New use cases identified"
          ]
        }
      ]
    },
    {
      "id": "intuitive",
      "name": "Intuitive Circle",
      "lead": "strategic-architect-agent",
      "purpose": "Provide strategic foresight and holistic system understanding",
      "domains": [
        "System architecture and design thinking",
        "User experience and workflow optimization",
        "Strategic planning and vision setting",
        "Cross-functional integration",
        "Organizational dynamics and culture"
      ],
      "standup": {
        "frequency": "weekly",
        "day": "thursday",
        "time": "12:00",
        "timezone": "UTC"
      },
      "retrospective": {
        "frequency": "monthly",
        "week": "first",
        "day": "friday",
        "time": "17:00",
        "timezone": "UTC"
      },
      "objectives": [
        {
          "id": "intuitive-001",
          "title": "Circle workflow architecture",
          "status": "completed",
          "priority": "high",
          "deadline": "2025-12-01",
          "keyResults": [
            "DoR/DoD framework defined",
            "P/D/A structure documented",
            "Cross-circle coordination designed",
            "Governance metrics established"
          ]
        },
        {
          "id": "intuitive-002",
          "title": "Integration design for multi-system coordination",
          "status": "in_progress",
          "priority": "medium",
          "deadline": "2025-12-15",
          "keyResults": [
            "GitHub/GitLab integration mapped",
            "Discord bot architecture defined",
            "Stripe payment flow designed",
            "StarlingX deployment workflow planned"
          ]
        }
      ]
    },
    {
      "id": "orchestrator",
      "name": "Orchestrator Circle",
      "lead": "workflow-coordinator-agent",
      "purpose": "Coordinate workflows and ensure smooth execution across all circles",
      "domains": [
        "Multi-agent coordination and task distribution",
        "CI/CD pipeline management",
        "Release planning and deployment coordination",
        "Dependency management and conflict resolution",
        "Resource allocation and capacity planning"
      ],
      "standup": {
        "frequency": "daily",
        "time": "13:00",
        "timezone": "UTC"
      },
      "retrospective": {
        "frequency": "bi-weekly",
        "week": "first,third",
        "day": "friday",
        "time": "13:00",
        "timezone": "UTC"
      },
      "objectives": [
        {
          "id": "orchestrator-001",
          "title": "GitHub/GitLab activity validation",
          "status": "in_progress",
          "priority": "high",
          "deadline": "2025-12-08",
          "keyResults": [
            "Repository activity tracked",
            "PR throughput measured",
            "Merge conflicts resolved < 4 hours",
            "CI/CD pipeline uptime > 99%"
          ]
        },
        {
          "id": "orchestrator-002",
          "title": "Deployment coordination optimization",
          "status": "planned",
          "priority": "medium",
          "deadline": "2025-12-15",
          "keyResults": [
            "Mean time to deploy < 10 minutes",
            "Zero-downtime deployments validated",
            "Rollback procedures tested",
            "Multi-environment coordination automated"
          ]
        }
      ]
    },
    {
      "id": "seeker",
      "name": "Seeker Circle",
      "lead": "knowledge-researcher-agent",
      "purpose": "Explore opportunities and maintain awareness of external developments",
      "domains": [
        "Market research and competitive analysis",
        "Technology trend monitoring",
        "Community engagement and partnerships",
        "Documentation and knowledge management",
        "Best practice research and adoption"
      ],
      "standup": {
        "frequency": "weekly",
        "day": "friday",
        "time": "14:00",
        "timezone": "UTC"
      },
      "retrospective": {
        "frequency": "monthly",
        "week": "last",
        "day": "friday",
        "time": "14:00",
        "timezone": "UTC"
      },
      "objectives": [
        {
          "id": "seeker-001",
          "title": "Documentation audit and update",
          "status": "in_progress",
          "priority": "medium",
          "deadline": "2025-12-08",
          "keyResults": [
            "All docs reviewed for accuracy",
            "OTEL_TELEMETRY.md verified current",
            "CIRCLES_DOD.md published",
            "GOVERNANCE_BASELINE.md completed"
          ]
        },
        {
          "id": "seeker-002",
          "title": "Best practices research for agentic workflows",
          "status": "planned",
          "priority": "low",
          "deadline": "2025-12-22",
          "keyResults": [
            "Holacracy training materials reviewed",
            "Industry case studies documented",
            "Recommendations for adoption created"
          ]
        }
      ]
    }
  ],
  "metrics": {
    "doRCompliance": {
      "target": 0.95,
      "measurement": "percentage_of_work_items_meeting_dor"
    },
    "doDCompliance": {
      "target": 0.90,
      "measurement": "percentage_of_work_items_meeting_dod"
    },
    "cycleTime": {
      "target": 5,
      "unit": "days",
      "measurement": "average_time_from_dor_to_dod"
    },
    "blockerResolution": {
      "target": 4,
      "unit": "hours",
      "measurement": "average_time_to_resolve_critical_blockers"
    },
    "crossCircleHandoff": {
      "target": 2,
      "unit": "hours",
      "measurement": "average_handoff_latency_between_circles"
    },
    "retroActionCompletion": {
      "target": 0.80,
      "measurement": "percentage_of_retro_actions_completed_on_time"
    }
  },
  "integrations": {
    "github": {
      "enabled": true,
      "repository": "agentic-flow",
      "issueLabels": {
        "analyst": "circle:analyst",
        "assessor": "circle:assessor",
        "innovator": "circle:innovator",
        "intuitive": "circle:intuitive",
        "orchestrator": "circle:orchestrator",
        "seeker": "circle:seeker"
      }
    },
    "ci": {
      "enabled": true,
      "provider": "github-actions",
      "workflows": [
        "ci-cd-pipeline.yml",
        "dependency-update-validation.yml",
        "pattern-telemetry-validation.yml"
      ]
    }
  },
  "reportingSchedule": {
    "standupSummary": "daily",
    "circleMetrics": "weekly",
    "governanceDashboard": "bi-weekly",
    "quarterlyReview": "quarterly"
  }
}
