{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "mutator": "javascript",
  "packageManager": "npm",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "testRunner": "command",
  "commandRunner": {
    "command": "npx playwright test tests/e2e/dashboard.spec.ts --project=chromium"
  },
  "coverageAnalysis": "off",
  "mutate": [
    "scripts/monitoring/dashboard_server.js"
  ],
  "timeoutMS": 10000,
  "concurrency": 2
}
