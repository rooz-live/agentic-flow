{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/core"
  },
  "include": [
    "src/core/**/*",
    "src/middleware/**/*",
    "src/refactored/**/*",
    "src/swarm/**/*",
    "src/transport/**/*",
    "src/llm/**/*",
    "src/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/components/**/*",
    "src/dashboard/**/*",
    "src/discord/**/*",
    "src/integrations/**/*",
    "src/monitoring/**/*",
    "src/trading/**/*",
    "src/App.tsx",
    "src/api/ceremony-scheduler.ts",
    "src/visualizations/**/*",
    "scripts/**/*",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
