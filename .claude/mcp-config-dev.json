{
  "mcpServers": {
    "agentic-qe": {
      "command": "npx",
      "args": ["aqe-mcp"],
      "env": {
        "AQE_MEMORY_PATH": ".agentic-qe/memory.db",
        "AQE_LEARNING_ENABLED": "true",
        "AQE_ENV": "dev",
        "NODE_NO_WARNINGS": "1"
      }
    }
  },
  "environment": {
    "name": "dev",
    "description": "Shared development environment",
    "risk_threshold": 6,
    "promotion_gate": "tests_pass_integration_security_scan",
    "escalation": "team_lead_24h",
    "restrictions": {
      "allow_production_tools": false,
      "allow_payment_processing": false,
      "allow_database_writes": true,
      "max_parallel_agents": 8,
      "sandbox_mode": true
    }
  },
  "tool_restrictions": {
    "blocked_tools": [
      "hostbill-payment-process",
      "stripe-live-charge",
      "paypal-live-payment",
      "production-database-write",
      "ssl-certificate-renew",
      "dns-record-update",
      "starlingx-production-deploy"
    ],
    "require_confirmation": [
      "external-api-call",
      "file-system-delete",
      "database-schema-change",
      "integration-test-external"
    ],
    "allowed_tools": [
      "test-runner",
      "lint-check",
      "mock-payment-process",
      "dev-database-query",
      "devstack-openstack-api",
      "stripe-test-charge",
      "paypal-sandbox-payment"
    ]
  },
  "integrations": {
    "openstack": {
      "tenant": "dev-tenant",
      "endpoint": "devstack-local"
    },
    "stripe": {
      "mode": "test",
      "key_prefix": "sk_test_"
    },
    "paypal": {
      "mode": "sandbox"
    }
  },
  "notes": {
    "purpose": "Integration testing with DevStack and sandbox payment gateways",
    "payment_mode": "test_keys_only",
    "database_mode": "shared_dev_postgres"
  }
}

