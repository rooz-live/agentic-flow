{
  "mcpServers": {
    "agentic-qe": {
      "command": "npx",
      "args": ["--yes", "aqe-mcp@2.5.10"],
      "env": {
        "AQE_MEMORY_PATH": ".agentic-qe/memory.db",
        "AQE_LEARNING_ENABLED": "true",
        "AQE_ENV": "local",
        "NODE_NO_WARNINGS": "1"
      }
    }
  },
  "environment": {
    "name": "local",
    "description": "Local development environment",
    "risk_threshold": 8,
    "promotion_gate": "tests_pass_and_peer_review",
    "restrictions": {
      "allow_production_tools": false,
      "allow_payment_processing": false,
      "allow_database_writes": true,
      "max_parallel_agents": 5,
      "sandbox_mode": true
    }
  },
  "integrations": {
    "hostbill": {
      "enabled": false,
      "api_url": "",
      "api_key_env": "HOSTBILL_API_KEY",
      "mode": "mock",
      "notes": "HostBill disabled in local - use mock mode for testing"
    },
    "starlingx": {
      "enabled": true,
      "ssh_host": "23.92.79.2",
      "ssh_port": 2222,
      "ssh_user": "root"
    },
    "openstack": {
      "enabled": true,
      "tenant": "development"
    }
  },
  "tool_restrictions": {
    "blocked_tools": [
      "hostbill-payment-process",
      "stripe-live-charge",
      "paypal-live-payment",
      "production-database-write",
      "ssl-certificate-renew",
      "dns-record-update"
    ],
    "require_confirmation": [
      "external-api-call",
      "file-system-delete"
    ],
    "allowed_tools": [
      "test-runner",
      "lint-check",
      "mock-payment-process",
      "local-database-query"
    ]
  },
  "notes": {
    "purpose": "Safe local development with mocked external services",
    "payment_mode": "test_keys_only",
    "database_mode": "local_sqlite_or_docker"
  }
}

