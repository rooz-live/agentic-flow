{
  "mcpServers": {
    "agentic-qe": {
      "command": "npx",
      "args": ["aqe-mcp"],
      "env": {
        "AQE_MEMORY_PATH": ".agentic-qe/memory.db",
        "AQE_LEARNING_ENABLED": "false",
        "AQE_ENV": "prod",
        "AQE_READONLY": "true",
        "NODE_NO_WARNINGS": "1"
      }
    }
  },
  "environment": {
    "name": "prod",
    "description": "Production environment - EXTREME CAUTION REQUIRED",
    "risk_threshold": 2,
    "promotion_gate": "stg_validation_production_readiness_review_cab_approval",
    "escalation": "oncall_immediate_incident_commander",
    "rollback_trigger": "any_p0_p1_incident_or_customer_impacting_bug",
    "restrictions": {
      "allow_production_tools": true,
      "allow_payment_processing": true,
      "payment_processing_mode": "live",
      "allow_database_writes": true,
      "max_parallel_agents": 3,
      "sandbox_mode": false,
      "require_change_ticket": true,
      "require_cab_approval": true,
      "break_glass_only": true
    }
  },
  "tool_restrictions": {
    "blocked_tools": [
      "test-data-generator",
      "mock-payment-process",
      "database-drop",
      "schema-migration-untested"
    ],
    "require_confirmation": [
      "ALL"
    ],
    "require_explicit_environment_confirmation": [
      "hostbill-payment-process",
      "stripe-live-charge",
      "paypal-live-payment",
      "production-database-write",
      "ssl-certificate-renew",
      "dns-record-update",
      "starlingx-production-deploy",
      "openstack-production-api"
    ],
    "allowed_tools": [
      "production-database-readonly",
      "monitoring-query",
      "log-analysis",
      "health-check"
    ]
  },
  "integrations": {
    "openstack": {
      "tenant": "production",
      "endpoint": "stx-aio-0.corp.interface.tag.ooo"
    },
    "stripe": {
      "mode": "live",
      "key_prefix": "sk_live_",
      "require_confirmation": true
    },
    "paypal": {
      "mode": "live",
      "require_confirmation": true
    },
    "hostbill": {
      "mode": "production",
      "domain": "billing.interface.tag.ooo",
      "require_confirmation": true
    }
  },
  "safety_guards": {
    "max_transaction_amount": 10000,
    "require_dual_approval_above": 5000,
    "auto_rollback_on_error_rate": 0.05,
    "circuit_breaker_enabled": true,
    "canary_deployment_required": true
  },
  "validation_gates": {
    "pre_deployment": [
      "stg_validation_complete",
      "production_readiness_review",
      "cab_approval",
      "rollback_plan_documented",
      "monitoring_alerts_configured"
    ],
    "post_deployment": [
      "smoke_test_passed",
      "key_metrics_nominal",
      "no_new_errors_5min"
    ]
  },
  "notes": {
    "purpose": "Production deployment with full safety guards",
    "payment_mode": "live_keys",
    "database_mode": "stx-aio-0_production_tenant",
    "warning": "ALL operations require explicit confirmation and audit logging"
  }
}

