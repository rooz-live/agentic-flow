{
  "mcpServers": {
    "agentic-qe": {
      "command": "npx",
      "args": ["--yes", "aqe-mcp@2.5.10"],
      "env": {
        "AQE_MEMORY_PATH": ".agentic-qe/memory.db",
        "AQE_LEARNING_ENABLED": "true",
        "AQE_ENV": "stg",
        "NODE_NO_WARNINGS": "1"
      }
    }
  },
  "environment": {
    "name": "stg",
    "description": "Staging environment (pre-production validation)",
    "risk_threshold": 4,
    "promotion_gate": "all_tests_load_tests_smoke_test_stakeholder_approval",
    "escalation": "engineering_manager_4h",
    "restrictions": {
      "allow_production_tools": false,
      "allow_payment_processing": true,
      "payment_processing_mode": "test_only",
      "allow_database_writes": true,
      "max_parallel_agents": 10,
      "sandbox_mode": false,
      "require_change_ticket": true
    }
  },
  "tool_restrictions": {
    "blocked_tools": [
      "stripe-live-charge",
      "paypal-live-payment",
      "production-database-write",
      "ssl-certificate-renew-prod",
      "dns-record-update-prod"
    ],
    "require_confirmation": [
      "hostbill-api-call",
      "stripe-test-charge",
      "paypal-sandbox-payment",
      "database-schema-change",
      "starlingx-staging-deploy",
      "openstack-resource-create"
    ],
    "allowed_tools": [
      "test-runner",
      "lint-check",
      "load-test-runner",
      "smoke-test-suite",
      "staging-database-query",
      "staging-openstack-api"
    ]
  },
  "integrations": {
    "openstack": {
      "tenant": "stg-tenant",
      "endpoint": "stx-aio-0-staging"
    },
    "stripe": {
      "mode": "test",
      "key_prefix": "sk_test_"
    },
    "paypal": {
      "mode": "sandbox"
    },
    "hostbill": {
      "enabled": true,
      "api_url": "https://billing-stg.interface.tag.ooo/admin/api.php",
      "api_key_env": "HOSTBILL_API_KEY",
      "mode": "staging",
      "notes": "Staging HostBill - test payments, read-write operations"
    },
    "starlingx": {
      "enabled": true,
      "ssh_host": "23.92.79.2",
      "ssh_port": 2222,
      "ssh_user": "root"
    }
  },
  "validation_gates": {
    "required_before_prod": [
      "load_test_passed",
      "security_scan_passed",
      "smoke_test_passed",
      "stakeholder_signoff",
      "no_p0_p1_bugs"
    ]
  },
  "notes": {
    "purpose": "Pre-production validation with production-like configuration",
    "payment_mode": "test_keys_only",
    "database_mode": "stx-aio-0_non_prod_tenant"
  }
}

