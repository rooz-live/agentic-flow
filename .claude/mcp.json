{
  "mcpServers": {
    "agentic-qe": {
      "command": "npx",
      "args": ["--yes", "agentic-qe@3.11.1", "mcp"],
      "env": {
        "AQE_ENV": "local",
        "AQE_LEARNING_ENABLED": "true"
      }
    },
    "claude-flow": {
      "command": "npx",
      "args": ["--yes", "claude-flow@alpha", "mcp", "start"],
      "env": {}
    },
    "ruflo": {
      "command": "npx",
      "args": ["--yes", "ruflo@3.14.1", "mcp", "start"],
      "env": {}
    },
    "context7": {
      "command": "npx",
      "args": ["--yes", "@upstash/context7-mcp@latest"],
      "env": {}
    },
    "filesystem": {
      "command": "npx",
      "args": ["--yes", "@modelcontextprotocol/server-filesystem@latest", "/Users/shahroozbhopti/Documents/code"],
      "env": {}
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["--yes", "@modelcontextprotocol/server-sequential-thinking@latest"],
      "env": {}
    }
  }
}
