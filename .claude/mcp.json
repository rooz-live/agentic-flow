{
  "mcpServers": {
    "agentic-qe": {
      "command": "npx",
      "args": [
        "aqe-mcp"
      ],
      "env": {
        "AQE_MEMORY_PATH": ".agentic-qe/memory.db",
        "AQE_LEARNING_ENABLED": "true",
        "NODE_NO_WARNINGS": "1"
      }
    },
    "claude-flow": {
      "command": "npx",
      "args": [
        "--yes",
        "claude-flow@alpha",
        "mcp",
        "start"
      ],
      "env": {
        "CLAUDE_FLOW_MEMORY_PATH": ".swarm/memory.db",
        "NODE_NO_WARNINGS": "1"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "--yes",
        "@upstash/context7-mcp@latest"
      ],
      "env": {
        "DEFAULT_MINIMUM_TOKENS": "10000",
        "NODE_NO_WARNINGS": "1"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "--yes",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {
        "NODE_NO_WARNINGS": "1"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "--yes",
        "@anthropic/mcp-server-filesystem",
        "--root",
        "."
      ],
      "env": {
        "NODE_NO_WARNINGS": "1"
      }
    }
  }
}
