# Agentic Flow - Environment Variables Template
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_ACCESS_KEY_ID="<REQUIRED>"
AWS_SECRET_ACCESS_KEY="<REQUIRED>"
AWS_REGION=us-west-1
AWS_DEFAULT_REGION=us-west-1

AF_TELEMETRY_SINK_PROVIDER=aws_lightsail
AF_TELEMETRY_SINK_AWS_REGION=us-east-1
AF_TELEMETRY_SINK_MAX_MONTHLY_USD=10
AF_TELEMETRY_SINK_HOSTNAME=syslog-sink-prod-aws-us-east-1-01.interface.tag.ooo
AF_TELEMETRY_SINK_ADMIN_SSH_CIDR="173.94.53.113/32"
AF_TELEMETRY_SINK_SYSLOG_SOURCE_CIDR="23.92.79.2/32"

# =============================================================================
# AI/LLM API Keys
# =============================================================================
ANTHROPIC_API_KEY="<REQUIRED>"
OPENAI_API_KEY="<REQUIRED>"
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
GEMINI_API_KEY=your_gemini_key_here

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_PASSWORD="<REQUIRED>"
POSTGRES_USER=postgres
POSTGRES_DB=agentic_flow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# CI/CD & Version Control
# =============================================================================
GITLAB_TOKEN="<REQUIRED>"
GITHUB_TOKEN=ghp_your_github_token_here

# =============================================================================
# Security & Secrets Management
# =============================================================================
PASSBOLT_API_TOKEN="<REQUIRED>"
PASSBOLT_API_URL="https://passbolt.example.com"

# =============================================================================
# Infrastructure & CDN
# =============================================================================
CLOUDFLARE_API_TOKEN="<REQUIRED>"
CLOUDFLARE_API_KEY="<REQUIRED>"
CLOUDFLARE_EMAIL="your_cloudflare_email@example.com"
CLOUDFLARE_ZONE_ID=your_zone_id_here

# =============================================================================
# Hosting & Control Panels
# =============================================================================
CPANEL_API_KEY="<REQUIRED>"
CPANEL_USERNAME=your_cpanel_username_here
CPANEL_HOST=cpanel.example.com

HOSTBILL_API_KEY="<REQUIRED>"
HOSTBILL_API_ID="<REQUIRED>"
HOSTBILL_URL="https://hostbill.example.com"

HIVELOCITY_API_KEY="<REQUIRED>"

# =============================================================================
# Payment Gateways
# =============================================================================

# Stripe
STRIPE_SECRET_KEY="<REQUIRED>"
STRIPE_PUBLIC_KEY="<REQUIRED>"
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# PayPal
PAYPAL_CLIENT_ID="<REQUIRED>"
PAYPAL_CLIENT_SECRET="<REQUIRED>"
PAYPAL_MODE="sandbox  # or 'live' for production"

# Klarna
KLARNA_USERNAME="<REQUIRED>"
KLARNA_PASSWORD="<REQUIRED>"
KLARNA_REGION="na  # or 'eu', 'oc'"

# Square
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_APPLICATION_ID=your_square_application_id_here
SQUARE_LOCATION_ID=your_square_location_id_here

# =============================================================================
# Communication Services
# =============================================================================

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_APPLICATION_ID=your_discord_app_id_here
DISCORD_PUBLIC_KEY=your_discord_public_key_here
DISCORD_GUILD_ID=your_guild_id_here

# Plivo (SMS/Voice)
PLIVO_AUTH_ID="<REQUIRED>"
PLIVO_AUTH_TOKEN="<REQUIRED>"

# Telnyx (SMS)
TELNYX_API_KEY="<REQUIRED>"

# =============================================================================
# Monitoring & Analytics
# =============================================================================
PROMETHEUS_PUSHGATEWAY_URL="http://localhost:9091"
GRAFANA_API_KEY=your_grafana_api_key_here

# =============================================================================
# Development & Testing
# =============================================================================
NODE_ENV="development  # development, staging, production"
LOG_LEVEL="info  # debug, info, warn, error"

# =============================================================================
# Agentic Flow Configuration
# =============================================================================
AF_CONTEXT="local  # local, prod-cycle, full-cycle"
AF_CIRCLE="orchestrator  # analyst, assessor, innovator, intuitive, orchestrator, seeker"
AF_DEPTH_LEVEL=0
GOALIE_DIR=.goalie

# =============================================================================
# Governance Configuration (from pattern metrics analysis)
# =============================================================================
AF_PROD_CYCLE_MODE="advisory  # advisory, enforcement, mutation"
AF_GOVERNANCE_EXECUTOR_DRY_RUN="1  # 1=dry-run (validate only), 0=live (apply mutations)"
AF_PROD_OBSERVABILITY_FIRST=1

# Pattern Mode Enforcement
AF_PATTERN_MODE_STRICT="true  # Enforce standardized modes for critical patterns"

# Mutation Safety
AF_MUTATION_SHADOW_MODE="true  # Enable shadow mode for high-risk mutations"
AF_MUTATION_HIGH_RISK_APPROVAL_REQUIRED="true  # Require manual approval for high-risk changes"

# Observability Coverage
AF_OBSERVABILITY_COVERAGE_TARGET="0.95  # Target 95%+ observability coverage"
AF_OBSERVABILITY_STRICT="true  # Strict observability enforcement"

# =============================================================================
# Feature Flags
# =============================================================================
AF_CIRCUIT_BREAKER_ENABLED=true
AF_CIRCUIT_BREAKER_THRESHOLD=5
AF_PATTERN_TELEMETRY_ENABLED=true

# =============================================================================
# Trading & Analytics (Optional)
# =============================================================================
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL="https://paper-api.alpaca.markets  # paper trading"

# =============================================================================
# End of Configuration
# =============================================================================
# Remember to:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual credentials in .env
# 3. Verify .env is in .gitignore
# 4. Never commit .env to version control
# 5. Rotate credentials regularly (see docs/SECURITY.md)

