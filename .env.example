# ==========================================
# SYSTEMIC.OS - CORE ENVIRONMENT VARIABLES
# ==========================================
# Strict Isolation: Out-of-repo configuration mapping

# --- E2B Sandboxing (Titanium Cage) ---
E2B_API_KEY="e2b_your_production_key_here"

# --- Edge Physics Execution ---
# Bypasses standard network latency, enforces physical SSD-to-Cache mapping
LLAMA_CPP_MMAP_ENABLED=1
LLAMA_MODEL_PATH="/models/OBLITERATUS-gemma-4-E4B-it.gguf"
MAX_MEMORY_MAPPED_MB=16384

# --- Python Swarm Orchestrator ---
# Set to 0 to disable mock mode and enforce physical execution limits
SWARM_MOCK_MODE=0
PYTHON_ENV="production"

# --- External Classifiers (N8N) ---
N8N_WEBHOOK_URL="https://n8n.internal/webhook/triage"

# --- Telemetry & Analytics ---
TELEMETRY_LOG_DIR="/var/log/systemic-os"
WSJF_LEDGER_PATH="./.goalie/genuine_telemetry.json"
