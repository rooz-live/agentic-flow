# Environment Configuration Template
# Generated from config/env.catalog.json
# DO NOT EDIT MANUALLY - Update env.catalog.json instead

# Default AWS region
AWS_REGION=us-west-1

# AWS access key (required for S3/EC2)
AWS_ACCESS_KEY_ID=

# AWS secret key
AWS_SECRET_ACCESS_KEY=

# Anthropic Claude API key
ANTHROPIC_API_KEY=

# OpenAI API key
OPENAI_API_KEY=

# Google AI API key
GOOGLE_API_KEY=

# Hivelocity infrastructure API key
HIVELOCITY_API_KEY=

# GitLab host
GITLAB_HOST=gitlab.rooz.live

# GitLab personal access token
GITLAB_TOKEN=

# cPanel host
CPANEL_HOST=cpanel.rooz.live

# cPanel API token
CPANEL_API_TOKEN=

# cPanel username
CPANEL_USER=rooz

# PostgreSQL host
POSTGRES_HOST=localhost

# PostgreSQL port
POSTGRES_PORT=5432

# PostgreSQL user
POSTGRES_USER=postgres

# PostgreSQL password
POSTGRES_PASSWORD=

# PostgreSQL database name
POSTGRES_DB=agentic_flow

# Redis host
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# API server port (Grafana uses 3000)
API_PORT=3001

# Frontend port
FRONTEND_PORT=3000

# Node environment (development/staging/production)
NODE_ENV=development

# Logging level
LOG_LEVEL=info

# StarlingX dev host
YOLIFE_STX_HOST=stx.rooz.live

# StarlingX SSH port
YOLIFE_STX_PORT=2222

# StarlingX SSH key path
YOLIFE_STX_KEY=~/.ssh/starlingx_key

# cPanel host for yolife
YOLIFE_CPANEL_HOST=cpanel.rooz.live

# cPanel SSH key path
YOLIFE_CPANEL_KEY=~/pem/rooz.pem

# GitLab host for yolife
YOLIFE_GITLAB_HOST=gitlab.rooz.live

# GitLab SSH key path
YOLIFE_GITLAB_KEY=~/pem/rooz.pem

# Stripe payment gateway secret key
STRIPE_SECRET_KEY=

# Stripe payment gateway public key
STRIPE_PUBLIC_KEY=

# PayPal client ID
PAYPAL_CLIENT_ID=

# PayPal client secret
PAYPAL_CLIENT_SECRET=

# Klarna payment gateway username
KLARNA_USERNAME=

# Klarna payment gateway password
KLARNA_PASSWORD=

# HostBill URL
HOSTBILL_URL=https://hostbill.rooz.live

# HostBill API ID
HOSTBILL_API_ID=

# HostBill API key
HOSTBILL_API_KEY=

# Cloudflare API token
CLOUDFLARE_API_TOKEN=

# Cloudflare API key (legacy)
CLOUDFLARE_API_KEY=

# Cloudflare account email
CLOUDFLARE_EMAIL=admin@rooz.live

# Passbolt API token
PASSBOLT_API_TOKEN=

# Discord bot token
DISCORD_TOKEN=

# Discord application client ID
DISCORD_CLIENT_ID=

# Discord application client secret
DISCORD_CLIENT_SECRET=

# Plivo SMS auth ID
PLIVO_AUTH_ID=

# Plivo SMS auth token
PLIVO_AUTH_TOKEN=

# Telnyx SMS API key
TELNYX_API_KEY=

# Fish Speech TTS API key
FISH_SPEECH_TTS_API_KEY=
