# E2B Sandbox Secure Configuration (Titanium Cage)
E2B_API_KEY="op://Personal/E2B API Key/password"

# Edge Physics Execution
LLAMA_CPP_MMAP_ENABLED=1
LLAMA_MODEL_PATH="/models/OBLITERATUS-gemma-4-E4B-it.gguf"
MAX_MEMORY_MAPPED_MB=16384

# Python Swarm Orchestrator (Physics Mode - NO MOCKS)
SWARM_MOCK_MODE=0
PYTHON_ENV="production"

# Native Telemetry Flow overrides
SWARM_SCALE_THRESHOLD="0.7"
RISK_DB_PATH="./risks.db"
WSJF_LEDGER_PATH="./.goalie/genuine_telemetry.json"

# OpenStack STX Cloud Bridge (LBEC Offload)
STX_AUTH_TOKEN=""  # ⚠️ REQUIRED: Get from tag.ooo dashboard
STX_ENDPOINT="https://stx.tag.ooo:8774/v2.1"
STX_IMAGE_REF="edge-node-playwright"
STX_FLAVOR_REF="m1.medium"

# GOVERNANCE MODE (STRICT | AUDIT | HYBRID)
GOVERNANCE_MODE="STRICT"
GOVERNANCE_SECRET="op://Personal/Agentic Flow Governance Secret/password"

# ACTIVATION SAFETY LIMITS
MAX_DOMAINS_PER_BATCH=50
MAX_CONCURRENT_PLAYWRIGHT=5
SAFETY_CIRCUIT_BREAKER=true
REQUIRE_TELEMETRY_VERIFICATION=true

# MODE SELECTION: [FA] Full Autonomous | [SA] Semi-Autonomous
ACTIVE_MODE="FA"

# CPANEL/WHM Edge Configurations (Zero-Trust Backup/Sync)
CPANEL_HOST="yo.tag.ooo"
CPANEL_USER="nwn"
CPANEL_PASSWORD="op://Personal/WHM CP root/pass"
CPANEL_PORT="2222"
WHM_API_TOKEN="op://Personal/WHM API Token/password"
