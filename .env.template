# Agentic Flow Environment Template
# Copy this file to .env.local and fill in your actual credentials
# NEVER commit .env.local to git!

# ============================================================================
# API Keys
# ============================================================================

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Cloudflare
CLOUDFLARE_API_KEY=your_cloudflare_key_here
CLOUDFLARE_EMAIL=your_cloudflare_email_here
CLOUDFLARE_API_TOKEN=your_cloudflare_token_here

# Hivelocity (Infrastructure)
HIVELOCITY_API_KEY=your_hivelocity_key_here

# ============================================================================
# AWS Credentials
# ============================================================================

AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-west-1

# ============================================================================
# Database Credentials
# ============================================================================

POSTGRES_PASSWORD=your_postgres_password_here
DATABASE_PASSWORD=your_database_password_here

# ============================================================================
# Integration Services
# ============================================================================

# GitLab
GITLAB_TOKEN=your_gitlab_token_here

# Passbolt (Password Manager)
PASSBOLT_API_TOKEN=your_passbolt_token_here

# HostBill (Billing)
HOSTBILL_API_KEY=your_hostbill_key_here
HOSTBILL_URL=your_hostbill_url_here
HOSTBILL_API_ID=your_hostbill_api_id_here

# cPanel
CPANEL_API_KEY=your_cpanel_key_here

# ============================================================================
# Payment Gateways (PRODUCTION - Handle with extreme care!)
# ============================================================================

# Stripe
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_PUBLIC_KEY=pk_live_your_key_here

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# Klarna
KLARNA_USERNAME=your_klarna_username_here
KLARNA_PASSWORD=your_klarna_password_here

# Square
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_APPLICATION_ID=your_square_app_id_here

# ============================================================================
# Health Check & Monitoring
# ============================================================================

# Network health check target (use public DNS like 1.1.1.1 for testing)
AF_HEALTH_CHECK_HOST=1.1.1.1

# ============================================================================
# Development/Testing Only (Safe to use these test keys)
# ============================================================================

# Stripe Test Keys (Safe - these are test mode keys)
STRIPE_TEST_SECRET_KEY=sk_test_2wPMWmzr3bEXzPEv4K9x1jLd00mb1SIPJT
STRIPE_TEST_PUBLIC_KEY=pk_test_0VP4TIfGV9J8mmD6duzAkFxh00hCNBlV73

# ============================================================================
# Agentic Flow Configuration
# ============================================================================

# Environment (development, staging, production)
AF_ENVIRONMENT=development

# Production cycle mode
AF_PROD_CYCLE_MODE=advisory

# Enable IRIS metrics
AF_ENABLE_IRIS_METRICS=0

# Autocommit settings (DANGEROUS - use with caution)
AF_ALLOW_CODE_AUTOCOMMIT=0
AF_FULL_CYCLE_AUTOCOMMIT=0

# Debug settings
AF_DEBUG_PATTERN_EVENTS=0
