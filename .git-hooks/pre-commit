#!/usr/bin/env bash
set -e

# Pre-Commit Hook: Code Quality & Security Validation
# Validates: No secrets, tests pass, linting clean, DoD criteria met
#
# Installation:
#   chmod +x .git-hooks/pre-commit
#   git config core.hooksPath .git-hooks

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔍 Running pre-commit validation..."

# Track failures
FAILED=0

# Get list of staged Python files
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

# 1. Check for secrets in code
echo -e "\n${YELLOW}[1/5]${NC} Checking for secrets..."

SECRET_PATTERNS=(
    "password\s*=\s*['\"][^'\"]*['\"]"
    "api[_-]?key\s*=\s*['\"][^'\"]*['\"]"
    "secret\s*=\s*['\"][^'\"]*['\"]"
    "token\s*=\s*['\"][^'\"]*['\"]"
    "AWS_SECRET_ACCESS_KEY"
    "ANTHROPIC_API_KEY"
    "BEGIN RSA PRIVATE KEY"
    "BEGIN PRIVATE KEY"
)

for pattern in "${SECRET_PATTERNS[@]}"; do
    # Get matches, excluding safe placeholders and documentation examples
    MATCHES=$(git diff --cached | grep -iE "$pattern" | \
        grep -vE '(<REQUIRED>|"your_[a-z_]+_here"|your-[a-z-]+-here|sk-ant-\.\.\.|"\.\.\."|\.example|# Example|# Placeholder|\[REDACTED\])' || true)
    
    if [ -n "$MATCHES" ]; then
        echo -e "${RED}❌ Found potential secret in staged files${NC}"
        echo "   Pattern: $pattern"
        echo "$MATCHES" | grep -iE "$pattern" --color=always
        FAILED=1
    fi
done

if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✅ No secrets found${NC}"
fi

# 2. Run linting on staged Python files
if [ -n "$STAGED_PY_FILES" ]; then
    echo -e "\n${YELLOW}[2/5]${NC} Running linting checks..."
    
    # Check if ruff is available
    if command -v ruff &> /dev/null; then
        if ruff check $STAGED_PY_FILES; then
            echo -e "${GREEN}✅ Linting passed${NC}"
        else
            echo -e "${RED}❌ Linting failed${NC}"
            FAILED=1
        fi
    # Fallback to flake8
    elif command -v flake8 &> /dev/null; then
        if flake8 --max-line-length=120 --ignore=E501,W503 $STAGED_PY_FILES; then
            echo -e "${GREEN}✅ Linting passed (flake8)${NC}"
        else
            echo -e "${RED}❌ Linting failed${NC}"
            FAILED=1
        fi
    else
        echo -e "${YELLOW}⚠️  No linter found (ruff or flake8), skipping${NC}"
    fi
else
    echo -e "\n${YELLOW}[2/5]${NC} No Python files staged, skipping linting"
fi

# 3. Run tests for modified files
echo -e "\n${YELLOW}[3/5]${NC} Running tests..."

if [ -n "$STAGED_PY_FILES" ]; then
    # Check if pytest is available
    if command -v pytest &> /dev/null; then
        # Find corresponding test files
        TEST_FILES=""
        for pyfile in $STAGED_PY_FILES; do
            # Skip test files themselves
            if [[ $pyfile == *"test_"* ]]; then
                TEST_FILES="$TEST_FILES $pyfile"
                continue
            fi
            
            # Look for corresponding test file
            dirname=$(dirname "$pyfile")
            basename=$(basename "$pyfile" .py)
            
            # Check common test locations
            test_paths=(
                "$dirname/test_${basename}.py"
                "$dirname/../tests/test_${basename}.py"
                "tests/test_${basename}.py"
                "tests/unit/test_${basename}.py"
            )
            
            for test_path in "${test_paths[@]}"; do
                if [ -f "$test_path" ]; then
                    TEST_FILES="$TEST_FILES $test_path"
                    break
                fi
            done
        done
        
        if [ -n "$TEST_FILES" ]; then
            if pytest $TEST_FILES -v --tb=short; then
                echo -e "${GREEN}✅ Tests passed${NC}"
            else
                echo -e "${RED}❌ Tests failed${NC}"
                FAILED=1
            fi
        else
            echo -e "${YELLOW}⚠️  No test files found for staged files${NC}"
        fi
    else
        echo -e "${YELLOW}⚠️  pytest not found, skipping tests${NC}"
    fi
else
    echo "No Python files to test"
fi

# 4. Check DoD criteria for modified scripts
echo -e "\n${YELLOW}[4/5]${NC} Checking DoD criteria..."

DOR_DOD_FILE="tests/DOR_DOD_CRITERIA.yaml"

if [ -f "$DOR_DOD_FILE" ]; then
    # Check if code_search.py or doc_query.py are modified
    if echo "$STAGED_PY_FILES" | grep -E "(code_search|doc_query)\.py" > /dev/null; then
        echo "Modified critical files detected, validating DoD..."
        
        # Run performance baseline tests if they exist
        if [ -f "tests/perf/test_baseline_performance.py" ]; then
            if pytest tests/perf/test_baseline_performance.py -v --tb=short -x; then
                echo -e "${GREEN}✅ DoD performance criteria met${NC}"
            else
                echo -e "${RED}❌ DoD performance criteria not met${NC}"
                echo "   Performance tests failed. Fix issues before committing."
                FAILED=1
            fi
        else
            echo -e "${YELLOW}⚠️  DoD performance tests not found${NC}"
        fi
    else
        echo "No critical files modified, skipping DoD checks"
    fi
else
    echo -e "${YELLOW}⚠️  DoD criteria file not found${NC}"
fi

# 5. Check for break-glass audit violations
echo -e "\n${YELLOW}[5/5]${NC} Checking break-glass compliance..."

if [ -f "scripts/break_glass.py" ]; then
    if python3 scripts/break_glass.py --verify; then
        echo -e "${GREEN}✅ Break-glass audit log verified${NC}"
    else
        echo -e "${RED}❌ Break-glass audit log integrity check failed${NC}"
        FAILED=1
    fi
else
    echo -e "${YELLOW}⚠️  break_glass.py not found${NC}"
fi

# Final verdict
echo ""
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✅ All pre-commit checks passed${NC}"
    exit 0
else
    echo -e "${RED}❌ Pre-commit validation failed${NC}"
    echo ""
    echo "Fix the issues above before committing."
    echo ""
    echo "To bypass (NOT RECOMMENDED):"
    echo "  git commit --no-verify"
    exit 1
fi
