{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":preserveSemverRanges",
    ":dependencyDashboard",
    "group:allNonMajor"
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/dist/**",
    "**/archive/**",
    "**/scratch/**"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchManagers": ["npm"],
      "matchPackageNames": ["@playwright/test", "playwright"],
      "groupName": "playwright packages"
    }
  ]
}
