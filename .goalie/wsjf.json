{
  "$schema": "https://raw.githubusercontent.com/agenticsorg/agentic-flow/main/.schemas/wsjf.schema.json",
  "version": "1.0.0",
  "last_updated": "2025-12-04T00:00:00Z",
  "source": "canonical",
  "description": "WSJF Single Source of Truth - Prioritization framework with ROAM risk mapping",
  
  "scoring_methodology": {
    "user_value": {
      "scale": "1-10",
      "description": "Business value and user impact"
    },
    "time_criticality": {
      "scale": "1-10",
      "description": "Urgency and time-sensitivity"
    },
    "risk_reduction": {
      "scale": "1-10",
      "description": "Risk mitigation and opportunity enablement (maps to ROAM framework)"
    },
    "job_size": {
      "scale": "1-10",
      "description": "Effort and complexity estimate"
    },
    "formula": "wsjf_score = (user_value + time_criticality + risk_reduction) / job_size"
  },

  "roam_framework": {
    "description": "Risk, Opportunity, Ambiguity, Mitigation tracking",
    "risk_levels": {
      "low": { "value": 1-3, "color": "green", "action": "Monitor" },
      "medium": { "value": 4-6, "color": "yellow", "action": "Plan mitigation" },
      "high": { "value": 7-8, "color": "orange", "action": "Active mitigation" },
      "critical": { "value": 9-10, "color": "red", "action": "Immediate action" }
    },
    "opportunity_levels": {
      "low": { "value": 1-3, "impact": "Minor improvement" },
      "medium": { "value": 4-6, "impact": "Significant improvement" },
      "high": { "value": 7-8, "impact": "Major strategic enabler" },
      "transformative": { "value": 9-10, "impact": "Game-changing" }
    }
  },

