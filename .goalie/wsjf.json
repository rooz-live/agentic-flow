      "target": 3600,
      "current": null,
      "unit": "seconds",
      "measurement": "time between af insight and git commit"
    },
    "wsjf_drift": {
      "target": 0.1,
      "current": 0.0,
      "measurement": "abs(actual_effort - estimated_effort) / estimated_effort"
    },
    "test_coverage": {
      "target": 0.80,
      "current": null,
      "measurement": "covered_lines / total_lines"
    }
