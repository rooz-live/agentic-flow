  "governance": {
    "wsjf_recalc_triggers": [
      "New critical blocker",
      "Risk level escalation",
      "Deadline change",
      "Resource availability change",
      "Dependency resolution"
    ],
    "audit_trail": true,
    "sync_targets": [
      ".goalie/CONSOLIDATED_ACTIONS.yaml",
      ".goalie/wsjf_tracker.jsonl",
      ".goalie/KANBAN_BOARD.yaml"
    ],
    "validation_rules": {
      "max_now_items": 5,
      "min_wsjf_score_for_now": 4.0,
      "require_roam_for_critical": true,
      "require_validation_for_patterns": true
    }
  },

  "learning_capture": {
    "description": "Integration with processGovernor.ts events",
    "goalie_integration": true,
    "event_types": [
      "wsjf_score_change",
      "priority_shift",
      "roam_update",
      "item_completion",
      "validation_status_change"
    ],
    "sync_to": ".goalie/cycle_log.jsonl"
  },

  "risk_db_integration": {
    "auto_init": true,
    "script": "scripts/metrics/init_risk_analytics_db.py",
    "database": ".goalie/risk_scores.db",
    "roam_sync": true
  },

  "baseline_metrics": {
    "action_completion_rate": {
      "target": 0.80,
      "current": 0.0,
      "measurement": "completed_items / total_items"
