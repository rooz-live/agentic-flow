AE,CAAC;QAClC,CAAC;QAED,OAAO,KAAK,CAAC,IAAI,CAAC,IAAI,CAAC,YAAY,CAAC,MAAM,EAAE,CAAC,CAAC;IAChD,CAAC;IAED;;OAEG;IACI,cAAc,CAAC,MAAe;QACnC,IAAI,MAAM,EAAE,CAAC;YACX,MAAM,OAAO,GAAG,IAAI,CAAC,WAAW,CAAC,GAAG,CAAC,MAAM,CAAC,CAAC;YAC7C,OAAO,OAAO,CAAC,CAAC,CAAC,CAAC,OAAO,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC;QAClC,CAAC;QAED,OAAO,KAAK,CAAC,IAAI,CAAC,IAAI,CAAC,WAAW,CAAC,MAAM,EAAE,CAAC,CAAC;IAC/C,CAAC;IAED;;OAEG;IACI,qBAAqB;QAC1B,OAAO,EAAE,GAAG,IAAI,CAAC,kBAAkB,EAAE,CAAC;IACxC,CAAC;IAED;;OAEG;IACI,eAAe;QACpB,OAAO,EAAE,GAAG,IAAI,CAAC,YAAY,EAAE,CAAC;IAClC,CAAC;IAED;;OAEG;IACI,sBAAsB,CAAC,IAAa;QACzC,IAAI,IAAI,EAAE,CAAC;YACT,MAAM,OAAO,GAAG,IAAI,CAAC,mBAAmB,CAAC,GAAG,CAAC,IAAI,CAAC,CAAC;YACnD,OAAO,OAAO,CAAC,CAAC,CAAC,CAAC,OAAO,CAAC,CAAC,CAAC,CAAC,EAAE,CAAC;QAClC,CAAC;QAED,OAAO,KAAK,CAAC,IAAI,CAAC,IAAI,CAAC,mBAAmB,CAAC,MAAM,EAAE,CAAC,CAAC;IACvD,CAAC;IAED;;OAEG;IACI,aAAa;QAClB,OAAO;YACL,WAAW,EAAE,IAAI,CAAC,MAAM,CAAC,MAAM;YAC/B,cAAc,EAAE,IAAI,CAAC,cAAc,CAAC,IAAI;YACxC,YAAY,EAAE,IAAI,CAAC,YAAY,CAAC,IAAI;YACpC,WAAW,EAAE,IAAI,CAAC,WAAW,CAAC,IAAI;YAClC,mBAAmB,EAAE,IAAI,CAAC,mBAAmB,CAAC,IAAI;YAClD,WAAW,EAAE,IAAI,CAAC,kBAAkB;YACpC,YAAY,EAAE,IAAI,CAAC,YAAY;YAC/B,WAAW,EAAE,IAAI,CAAC,cAAc,CAAC,CAAC,CAAC;YACnC,YAAY,EAAE,IAAI,CAAC,eAAe,CAAC,CAAC,CAAC;YACrC,WAAW,EAAE,MAAM,CAAC,WAAW,CAAC,IAAI,CAAC,WAAW,CAAC;SAClD,CAAC;IACJ,CAAC;IAED;;OAEG;IACI,MAAM;QACX,OAAO;YACL,MAAM,EAAE,IAAI,CAAC,MAAM,CAAC,KAAK,CAAC,CAAC,IAAI,CAAC,EAAE,mBAAmB;YACrD,cAAc,EAAE,KAAK,CAAC,IAAI,CAAC,IAAI,CAAC,cAAc,CAAC,OAAO,EAAE,CAAC;YACzD,YAAY,EAAE,KAAK,CAAC,IAAI,CAAC,IAAI,CAAC,YAAY,CAAC,OAAO,EAAE,CAAC;YACrD,WAAW,EAAE,KAAK,CAAC,IAAI,CAAC,IAAI,CAAC,WAAW,CAAC,OAAO,EAAE,CAAC;YACnD,mBAAmB,EAAE,KAAK,CAAC,IAAI,CAAC,IAAI,CAAC,mBAAmB,CAAC,OAAO,EAAE,CAAC;YACnE,kBAAkB,EAAE,IAAI,CAAC,kBAAkB;YAC3C,YAAY,EAAE,IAAI,CAAC,YAAY;YAC/B,UAAU,EAAE,IAAI,IAAI,EAAE,CAAC,WAAW,EAAE;SACrC,CAAC;IACJ,CAAC;IAED;;OAEG;IACI,KAAK,CAAC,QAAQ;QACnB,eAAe;QACf,MAAM,IAAI,CAAC,WAAW,EAAE,CAAC;QAEzB,wBAAwB;QACxB,IAAI,CAAC,mBAAmB,EAAE,CAAC;QAE3B,OAAO,CAAC,GAAG,CAAC,wCAAwC,CAAC,CAAC;IACxD,CAAC;CACF;AA7uBD,4CA6uBC",
      names: [],
      sources: ["/Users/shahroozbhopti/Documents/code/investing/agentic-flow/src/discord/core/analytics_manager.ts"],
      sourcesContent: ["/**\n * Analytics Manager for Discord Bot\n * Handles monitoring, metrics collection, and performance analytics\n */\n\nimport { Guild, User, CommandInteraction, ButtonInteraction, Message } from 'discord.js';\nimport { EventEmitter } from 'events';\nimport { DiscordBotConfig } from './discord_config';\n\nexport interface AnalyticsEvent {\n  id: string;\n  type: 'command' | 'button_click' | 'message' | 'guild_join' | 'guild_leave' | 'error' | 'notification';\n  timestamp: Date;\n  userId?: string;\n  guildId?: string;\n  data: Record<string, any>;\n  metadata?: Record<string, any>;\n}\n\nexport interface CommandMetrics {\n  commandName: string;\n  totalUses: number;\n  uniqueUsers: Set<string>;\n  averageExecutionTime: number;\n  successRate: number;\n  errors: number;\n  lastUsed: Date;\n  usersByGuild: Map<string, Set<string>>;\n}\n\nexport interface GuildMetrics {\n  guildId: string;\n  name: string;\n  memberCount: number;\n  activeUsers: number;\n  commandUsage: Map<string, number>;\n  joinDate: Date;\n  lastActivity: Date;\n  features: {\n    tradingEnabled: boolean;\n    paymentsEnabled: boolean;\n    governanceEnabled: boolean;\n  };\n}\n\nexport interface UserMetrics {\n  userId: string;\n  username: string;\n  joinDate: Date;\n  lastActivity: Date;\n  totalCommands: number;\n  favoriteCommands: Map<string, number>;\n  guilds: Set<string>;\n  engagement: {\n    daily: number;\n    weekly: number;\n    monthly: number;\n  };\n  riskScore: number;\n  trustLevel: 'low' | 'medium' | 'high' | 'trusted';\n}\n\nexport interface PerformanceMetrics {\n  uptime: number;\n  memoryUsage: NodeJS.MemoryUsage;\n  cpuUsage: NodeJS.CpuUsage;\n  responseTime: {\n    average: number;\n    p95: number;\n    p99: number;\n  };\n  errorRate: number;\n  requestsPerSecond: number;\n  activeConnections: number;\n}\n\nexport interface NotificationMetrics {\n  type: string;\n  sent: number;\n  delivered: number;\n  failed: number;\n  averageDeliveryTime: number;\n  byPriority: Record<string, number>;\n  byChannel: Record<string, number>;\n}\n\nexport interface SystemHealth {\n  status: 'healthy' | 'degraded' | 'unhealthy';\n  checks: {\n    database: boolean;\n    api: boolean;\n    discord: boolean;\n    integrations: Record<string, boolean>;\n  };\n  issues: string[];\n  lastCheck: Date;\n}\n\nexport class AnalyticsManager extends EventEmitter {\n  private config: DiscordBotConfig;\n  private events: AnalyticsEvent[] = [];\n  private commandMetrics: Map<string, CommandMetrics> = new Map();\n  private guildMetrics: Map<string, GuildMetrics> = new Map();\n  private userMetrics: Map<string, UserMetrics> = new Map();\n  private notificationMetrics: Map<string, NotificationMetrics> = new Map();\n  private performanceMetrics: PerformanceMetrics;\n  private systemHealth: SystemHealth;\n  private responseTimes: number[] = [];\n  private errorCounts: Map<string, number> = new Map();\n\n  constructor(config: DiscordBotConfig) {\n    super();\n    this.config = config;\n    this.initializeMetrics();\n  }\n\n  /**\n   * Initialize analytics manager\n   */\n  public async initialize(): Promise<void> {\n    // Load existing metrics\n    await this.loadMetrics();\n    \n    // Setup periodic data collection\n    this.setupPeriodicCollection();\n    \n    // Setup cleanup routines\n    this.setupCleanupRoutines();\n    \n    console.log('\u2705 Analytics manager initialized');\n  }\n\n  /**\n   * Initialize metrics\n   */\n  private initializeMetrics(): void {\n    this.performanceMetrics = {\n      uptime: 0,\n      memoryUsage: process.memoryUsage(),\n      cpuUsage: process.cpuUsage(),\n      responseTime: {\n        average: 0,\n        p95: 0,\n        p99: 0\n      },\n      errorRate: 0,\n      requestsPerSecond: 0,\n      activeConnections: 0\n    };\n\n    this.systemHealth = {\n      status: 'healthy',\n      checks: {\n        database: false,\n        api: false,\n        discord: false,\n        integrations: {}\n      },\n      issues: [],\n      lastCheck: new Date()\n    };\n  }\n\n  /**\n   * Log Discord interaction\n   */\n  public async logInteraction(interaction: CommandInteraction | ButtonInteraction): Promise<void> {\n    const eventType = interaction.isCommand() ? 'command' : 'button_click';\n    \n    const event: AnalyticsEvent = {\n      id: `evt_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,\n      type: eventType,\n      timestamp: new Date(),\n      userId: interaction.user.id,\n      guildId: interaction.guild?.id,\n      data: {\n        interactionId: interaction.id,\n        type: interaction.type\n      },\n      metadata: {\n        commandName: (interaction as any).commandName,\n        customId: (interaction as any).customId\n      }\n    };\n\n    if (interaction.isCommand()) {\n      const startTime = Date.now();\n      \n      // Update command metrics\n      await this.updateCommandMetrics(interaction as CommandInteraction, startTime);\n      \n      // Track response time\n      this.trackResponseTime(Date.now() - startTime);\n    }\n\n    this.events.push(event);\n    this.emit('analytics_event', event);\n  }\n\n  /**\n   * Log message\n   */\n  public async logMessage(message: Message): Promise<void> {\n    const event: AnalyticsEvent = {\n      id: `msg_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,\n      type: 'message',\n      timestamp: new Date(),\n      userId: message.author.id,\n      guildId: message.guild?.id,\n      data: {\n        messageId: message.id,\n        contentLength: message.content.length,\n        hasAttachments: message.attachments.size > 0,\n        hasEmbeds: message.embeds.length > 0\n      },\n      metadata: {\n        channelType: message.channel.type,\n        isBot: message.author.bot\n      }\n    };\n\n    this.events.push(event);\n    this.updateUserActivity(message.author.id, message.guild?.id);\n    this.emit('analytics_event', event);\n  }\n\n  /**\n   * Log guild join\n   */\n  public async logGuildJoin(guild: Guild): Promise<void> {\n    const event: AnalyticsEvent = {\n      id: `join_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,\n      type: 'guild_join',\n      timestamp: new Date(),\n      guildId: guild.id,\n      data: {\n        guildName: guild.name,\n        memberCount: guild.memberCount,\n        ownerId: guild.ownerId\n      }\n    };\n\n    this.events.push(event);\n    this.updateGuildMetrics(guild);\n    this.emit('analytics_event', event);\n  }\n\n  /**\n   * Log guild leave\n   */\n  public async logGuildLeave(guild: Guild): Promise<void> {\n    const event: AnalyticsEvent = {\n      id: `leave_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,\n      type: 'guild_leave',\n      timestamp: new Date(),\n      guildId: guild.id,\n      data: {\n        guildName: guild.name,\n        memberCount: guild.memberCount\n      }\n    };\n\n    this.events.push(event);\n    this.guildMetrics.delete(guild.id);\n    this.emit('analytics_event', event);\n  }\n\n  /**\n   * Log error\n   */\n  public async logError(error: Error, context?: Record<string, any>): Promise<void> {\n    const errorType = error.constructor.name;\n    const currentCount = this.errorCounts.get(errorType) || 0;\n    this.errorCounts.set(errorType, currentCount + 1);\n\n    const event: AnalyticsEvent = {\n      id: `err_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,\n      type: 'error',\n      timestamp: new Date(),\n      data: {\n        errorType,\n        message: error.message,\n        stack: error.stack\n      },\n      metadata: context\n    };\n\n    this.events.push(event);\n    this.updateErrorRate();\n    this.emit('analytics_event', event);\n  }\n\n  /**\n   * Log notification\n   */\n  public async logNotification(\n    type: string,\n    userId: string,\n    success: boolean,\n    deliveryTime?: number\n  ): Promise<void> {\n    const event: AnalyticsEvent = {\n      id: `notif_${Date.now()}_${Math.random().toString(36).s