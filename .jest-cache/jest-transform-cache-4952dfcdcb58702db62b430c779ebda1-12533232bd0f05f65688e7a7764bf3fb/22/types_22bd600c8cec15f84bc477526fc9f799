rage (pattern-coverage)\n  pattern_hit_pct?: {\n    hit_pct: number;\n    patterns_hit: number;\n    patterns_total: number;\n    required_patterns: string[];\n    pattern_hits: Record<string, number>;\n  };\n  \n  // Production cycle qualification (winner-grade)\n  prod_cycle_qualification?: {\n    grade: 'bronze' | 'silver' | 'gold' | 'platinum';\n    ok_rate: number;\n    rev_per_h: number;\n    duration_ok_pct: number;\n    abort_count: number;\n    contention_mult: number;\n    checks_passed: number;\n    checks_total: number;\n  };\n  \n  // Detailed economic metrics (economic)\n  economic_metrics?: {\n    infrastructure_utilization: number;\n    capex_opex_ratio: number;\n    cost_of_delay: number;\n    time_criticality: number;\n    risk_reduction: number;\n    job_duration: number;\n    user_business_value: number;\n  };\n  \n  // Phase progression (phase-progression)\n  phase_progression?: {\n    current_phase: string;\n    phases_completed: string[];\n    progression_pct: number;\n    phase_duration_ms: number;\n  };\n  \n  // Security audit (security-audit)\n  security_audit_gaps?: {\n    sec_audit_issues: Array<{\n      id: string;\n      description: string;\n      severity: 'low' | 'medium' | 'high' | 'critical';\n    }>;\n    cve_count: number;\n    cve_list: Array<{\n      id: string;\n      severity: string;\n    }>;\n  };\n  \n  // Circle perspective telemetry (decision-lens)\n  decision_lens_telemetry?: {\n    backlog_coverage_pct: number;\n    telemetry_coverage_pct: number;\n    circle_perspectives: Array<{\n      circle: string;\n      backlog: boolean;\n      events: number;\n      depth_pct: number;\n      target: number;\n      lens: string;\n    }>;\n  };\n  \n  // Concurrency analysis (contention-analysis)\n  contention_analysis?: {\n    duration_multiplier: number;\n    efficiency_multiplier: number;\n    max_concurrency: number;\n    recommended_concurrency: number;\n    contention_score: number;\n  };\n  \n  // A/B testing results (variant-analysis)\n  variant_analysis?: {\n    variant_label: string;\n    iterations: number;\n    reps: number;\n    statistical_significance: boolean;\n    confidence_interval: [number, number];\n    effect_size: number;\n  };\n}\n\nexport interface VariantInfo {\n  label: string;\n  iters: number;\n  reps: number;\n  baseline?: boolean;\n}\n\nexport interface EvidenceConfig {\n  // Default emitters for --default-emitters flag\n  default_emitters: EvidenceEmitter[];\n  \n  // Eitter-specific configurations\n  emitter_configs: Record<EvidenceEmitter, {\n    enabled: boolean;\n    sampling_rate?: number;\n    thresholds?: Record<string, number>;\n    output_format?: 'json' | 'tsv' | 'yaml';\n  }>;\n  \n  // Graduation thresholds\n  graduation: {\n    green_streak_required: number;\n    shadow_cycles_before_recommend: number;\n    retro_approval_required: boolean;\n    max_sys_state_err: number;\n    max_abort: number;\n    max_autofix_adv_per_cycle: number;\n    min_stability_score: number;\n    min_ok_rate: number;\n  };\n}\n\nexport interface EvidenceSummary {\n  run_id: string;\n  timestamp: string;\n  total_events: number;\n  emitters_used: EvidenceEmitter[];\n  overall_grade?: 'bronze' | 'silver' | 'gold' | 'platinum';\n  readiness_score: number;\n  recommendations: Array<{\n    priority: 'critical' | 'high' | 'medium' | 'low';\n    category: string;\n    action: string;\n    impact: string;\n    auto_fixable: boolean;\n  }>;\n}\n"],
