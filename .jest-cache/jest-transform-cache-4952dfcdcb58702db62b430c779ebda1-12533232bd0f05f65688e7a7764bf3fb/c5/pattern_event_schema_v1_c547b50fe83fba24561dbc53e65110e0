{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentic-flow.dev/schemas/pattern_event_v1.json",
  "title": "Pattern Event Schema v1",
  "description": "Schema for pattern_metrics.jsonl events used in Decision Transformer training",
  "type": "object",
  "required": ["ts", "run_id", "pattern", "iteration", "circle", "depth"],
  "properties": {
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp"
    },
    "run_id": {
      "type": "string",
      "description": "Unique run identifier"
    },
    "pattern": {
      "type": "string",
      "description": "Pattern name (e.g., safe-degrade, ml-training-guardrail)"
    },
    "iteration": {
      "type": "integer",
      "minimum": 0,
      "description": "Iteration number within the run"
    },
    "circle": {
      "type": "string",
      "description": "Circle context (e.g., primary, secondary)"
    },
    "depth": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "description": "Depth level (1-4)"
    },
    "mode": {
      "type": "string",
      "enum": ["advisory", "enforcement", "mutation"],
      "description": "Execution mode"
    },
    "mutation": {
      "type": "boolean",
      "description": "Whether this event mutated state"
    },
    "gate": {
      "type": "string",
      "description": "Gate type for governance patterns"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Workload tags (ML, HPC, Stats, Device/Web, Federation)"
    },
    "framework": {
      "type": "string",
      "description": "ML framework (torch, tensorflow, jax)"
    },
    "trigger_reason": {
      "type": "string",
      "description": "Reason for pattern trigger"
    },
    "degraded_to": {
      "type": "string",
      "description": "State degraded to (for safe-degrade pattern)"
    },
    "economic": {
      "type": "object",
      "properties": {
        "cod": {
          "type": "number",
          "minimum": 0,
          "description": "Cost of Delay"
        },
        "wsjf_score": {
          "type": "number",
          "minimum": 0,
          "description": "Weighted Shortest Job First score"
        },
        "job_size": {
          "type": "number",
          "minimum": 0,
          "description": "Job size estimate"
        },
        "risk_reduction": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Risk reduction factor"
        }
      },
      "description": "Economic metrics"
    },
    "timeline": {
      "type": "object",
      "properties": {
        "signature": {
          "type": "string",
          "description": "Ed25519 signature (hex)"
        },
        "keyId": {
          "type": "string",
          "description": "Signing key identifier"
        },
        "algorithm": {
          "type": "string",
          "enum": ["Ed25519"],
          "description": "Signature algorithm"
        },
        "signedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Signature timestamp"
        }
      },
      "description": "Timeline signature (SAFLA-003)"
    },
    "merkle": {
      "type": "object",
      "properties": {
        "merkleHash": {
          "type": "string",
          "description": "Current Merkle hash"
        },
        "previousMerkleHash": {
          "type": "string",
          "description": "Previous Merkle hash in chain"
        },
        "index": {
          "type": "integer",
          "minimum": 0,
          "description": "Index in Merkle chain"
        }
      },
      "description": "Merkle chain info (SAFLA-002)"
    }
  }
}

