+#!/usr/bin/env bash
+# CPU governor guard - blocks if idle < threshold
+IDLE_MIN=${AF_CPU_IDLE_MIN:-50}
+IDLE_PCT=$(top -l 1 | grep "CPU usage" | awk '{print $7}' | sed 's/%//')
+
+if (( $(echo "$IDLE_PCT < $IDLE_MIN" | bc -l) )); then
+  echo "⚠️  CPU idle ${IDLE_PCT}% < ${IDLE_MIN}% threshold - operation blocked"
+  exit 1
+fi
+
+exec "$@"
+```
