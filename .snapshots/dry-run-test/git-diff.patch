+# Pattern Event Logging - Canonical Schema
+# =========================================
+# Helper function to emit pattern events conforming to canonical schema
+# Usage: emit_pattern_event <pattern> <mode> <gate> <circle> <depth> [<mutation>] [<extra_fields>]
+emit_pattern_event() {
+    local pattern="$1"
+    local mode="$2"              # advisory, enforcement, mutation
+    local gate="$3"              # health, governance, wsjf, focus
+    local circle="${4:-Orchestrator}"
+    local depth="${5:-2}"
+    local mutation="${6:-false}"
+    local extra_fields="${7:-}"
+    
+    # Generate required fields
+    local ts=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
+    local run="${AF_CURRENT_RUN:-prod-cycle}"
+    local run_id="${AF_CURRENT_RUN_ID:-run-$(date +%Y%m%d%H%M%S)}"
+    local iteration="${AF_CURRENT_ITERATION:-1}"
+    local framework="${AF_FRAMEWORK:-}"
+    local scheduler="${AF_SCHEDULER:-}"
+    
+    # Default tags based on pattern type
+    local tags='[]'
+    if [[ "$pattern" == *"ml-"* ]] || [[ "$pattern" == *"training"* ]]; then
+        tags='["ML"]'
+    elif [[ "$pattern" == *"hpc-"* ]] || [[ "$pattern" == *"batch"* ]]; then
+        tags='["HPC"]'
+    elif [[ "$pattern" == *"stat-"* ]]; then
+        tags='["Stats"]'
+    elif [[ "$pattern" == *"mobile-"* ]] || [[ "$pattern" == *"desktop-"* ]] || [[ "$pattern" == *"web-"* ]]; then
+        tags='["Device/Web"]'
+    elif [[ "$pattern" == *"governance"* ]] || [[ "$pattern" == *"retro"* ]]; then
+        tags='["Federation"]'
+    fi
+    
+    # Default economic values (can be overridden in extra_fields)
+    local cod="${AF_PATTERN_COD:-0.0}"
+    local wsjf_score="${AF_PATTERN_WSJF:-0.0}"
+    
+    # Build base event
+    local event=$(cat <<EOF
+{
+  "ts": "$ts",
+  "run": "$run",
+  "run_id": "$run_id",
+  "iteration": $iteration,
+  "circle": "$circle",
+  "depth": $depth,
+  "pattern": "$pattern",
+  "mode": "$mode",
+  "mutation": $mutation,
+  "gate": "$gate",
+  "framework": "$framework",
+  "scheduler": "$scheduler",
+  "tags": $tags,
+  "economic": {
+    "cod": $cod,
+    "wsjf_score": $wsjf_score
+  }$([[ -n "$extra_fields" ]] && echo "," || echo "")
+  $extra_fields
+}
+EOF
+)
+    
+    # Write to pattern metrics and cycle log
+    local pattern_metrics_file="$PROJECT_ROOT/.goalie/pattern_metrics.jsonl"
+    local cycle_log_file="$PROJECT_ROOT/.goalie/cycle_log.jsonl"
+    
+    mkdir -p "$(dirname "$pattern_metrics_file")"
+    
+    # Minify JSON for storage
+    echo "$event" | jq -c '.' >> "$pattern_metrics_file" 2>/dev/null || echo "$event" >> "$pattern_metrics_file"
+    echo "$event" | jq -c '.' >> "$cycle_log_file" 2>/dev/null || echo "$event" >> "$cycle_log_file"
+    
+    if [ "${AF_DEBUG_PATTERN_EVENTS:-0}" = "1" ]; then
+        echo -e "${BLUE}[pattern_event] Logged $pattern event to pattern_metrics.jsonl${NC}" >&2
+    fi
+}
+
