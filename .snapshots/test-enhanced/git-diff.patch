+/// Governance probe tool – surfaces agentic-jujutsu status and optionally logs heartbeat.
+pub struct GovernanceProbeTool {
+    pub goalie_dir: Option<PathBuf>,
+}
+
+impl GovernanceProbeTool {
+    pub fn new(goalie_dir: Option<PathBuf>) -> Self {
+        Self { goalie_dir }
+    }
