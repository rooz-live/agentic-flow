+#[async_trait]
+impl McpTool for GovernanceProbeTool {
+    fn name(&self) -> &str {
+        "governance_probe"
+    }
+
+    fn description(&self) -> &str {
+        "Probe agentic-jujutsu governance wiring and optionally log a .goalie heartbeat"
+    }
+
+    fn input_schema(&self) -> JsonValue {
+        serde_json::json!({
+            "type": "object",
+            "properties": {
+                "goalie_dir": {"type": "string"},
+                "write_heartbeat": {"type": "boolean", "default": true}
+            }
+        })
+    }
+
+    async fn execute(&self, params: JsonValue) -> Result<JsonValue> {
+        #[derive(Deserialize)]
+        struct Input {
+            goalie_dir: Option<String>,
+            write_heartbeat: Option<bool>,
+        }
+
+        let input: Input = serde_json::from_value(params)?;
+
+        let probe: GovernanceProbeResult = probe_governance().await;
+
+        let mut heartbeat_written = false;
+        let mut heartbeat_error: Option<String> = None;
+
+        let should_write = input.write_heartbeat.unwrap_or(true);
+        if should_write {
+            let base_dir = input
+                .goalie_dir
+                .map(PathBuf::from)
+                .or_else(|| self.goalie_dir.clone())
+                .unwrap_or_else(|| PathBuf::from(".goalie"));
+
+            if let Err(e) = write_governance_heartbeat(&base_dir, &probe) {
+                heartbeat_error = Some(e.to_string());
+            } else {
+                heartbeat_written = true;
+            }
+        }
+
+        Ok(serde_json::json!({
+            "ok": probe.ok,
+            "message": probe.message,
+            "heartbeat_written": heartbeat_written,
+            "heartbeat_error": heartbeat_error,
+        }))
+    }
+}
