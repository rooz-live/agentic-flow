# TLD Configuration for Dashboard Deployment
# Sets default values for non-localhost TLD HTTP servers

# Default environment for deployments
DASHBOARD_DEFAULT_ENV=staging

# Domain mappings for different environments
DASHBOARD_DOMAIN_PROD=interface.rooz.live
DASHBOARD_DOMAIN_STAGING=staging.interface.rooz.live
DASHBOARD_DOMAIN_DEV=dev.interface.rooz.live

# Special purpose domains
DASHBOARD_DOMAIN_GATEWAY=pur.tag.vote
DASHBOARD_DOMAIN_EVIDENCE=hab.yo.life
DASHBOARD_DOMAIN_PROCESS=file.720.chat

# Server configuration
DASHBOARD_DEFAULT_PORT=80
DASHBOARD_BIND_ADDRESS=0.0.0.0
DASHBOARD_SSL_ENABLED=true

# Tunnel provider preferences
TUNNEL_PREFERENCE_ORDER=ngrok,tailscale,cloudflare,localtunnel

# Use TLD by default (set to false for localhost development)
USE_TLD_BY_DEFAULT=true
