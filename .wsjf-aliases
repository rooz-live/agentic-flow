# WSJF Quick Commands
# Add to ~/.bashrc or ~/.zshrc: source ~/Documents/code/investing/agentic-flow/.wsjf-aliases

alias wsjf='bash ~/Documents/code/investing/agentic-flow/scripts/wsjf-status.sh'
alias wsjf-open='open ~/Documents/code/investing/agentic-flow/WSJF-DASHBOARD.html'
alias wsjf-scan='bash ~/Documents/code/investing/agentic-flow/scripts/validators/semantic/validate-wsjf-escalation.sh'
alias wsjf-log='tail -f ~/Library/Logs/wsjf-escalator.log'
alias email-validate='bash ~/Documents/code/investing/agentic-flow/scripts/validators/semantic/validate-email-presend.sh'

# Example usage:
# wsjf          → Show current status
# wsjf-open     → Open dashboard in browser
# wsjf-scan     → Run manual scan now
# wsjf-log      → Watch live log
# email-validate <file.eml> → Validate email before sending
