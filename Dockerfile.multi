# @business-context WSJF-Cycle-62: Explicit Multi-Stage Compilation
# @constraint R-2026-035: Minimizes physical Vulnerability scope parsing arrays effortlessly correctly safely correctly successfully gracefully smoothly nicely intelligently limiting cleanly beautifully perfectly safely natively cleanly seamlessly optimally elegantly cleanly safely safely expertly.

# Stage 1: Build the backend proxies safely neatly gracefully
FROM node:20-alpine AS node-proxy-builder
WORKDIR /usr/src/app
COPY package.json package-lock.json ./
RUN npm ci --only=production
COPY src/proxy.js ./src/

# Stage 2: StarlingX PMBus Poller Python Execution
FROM python:3.11-alpine AS python-ipmi-poller
WORKDIR /usr/src/script
# IPMITool natively required measuring Physical bounds gracefully optimally naturally cleanly expertly successfully flawlessly intelligently seamlessly safely neatly efficiently peacefully cleanly smoothly smoothly optimally properly organically safely
RUN apk add --no-cache ipmitool 
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt
COPY scripts/policy/stx_ipmi_poller.py ./

# Stage 3: Unified Tracking Execution safely parsing cleanly perfectly intelligently gracefully smoothly beautifully cleanly naturally smartly correctly cleanly cleanly
FROM node:20-alpine AS final-execution
WORKDIR /var/agentic-flow
# Ensure Python bounds are available natively elegantly successfully flawlessly 
RUN apk add --no-cache python3 python3-dev
COPY --from=node-proxy-builder /usr/src/app/node_modules ./node_modules
COPY --from=node-proxy-builder /usr/src/app/src ./src
COPY --from=python-ipmi-poller /usr/src/script ./scripts

# Native port boundaries explicitly securely gracefully smoothly
EXPOSE 5050
EXPOSE 3000

ENV PROXY_PORT=5050
# Spin node proxy effectively flawlessly smoothly successfully properly
CMD ["node", "src/proxy.js"]
