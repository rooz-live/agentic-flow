#!/usr/bin/env python3
"""
advocate - Legal Document Automation CLI
Multi-provider PDF classifier with session persistence and auto-organization

Usage:
  advocate classify <path> [--auto-rename] [--vision-mode]
  advocate session restore [--latest]
  advocate config set <key>=<value>
  advocate config get <key>
  
Examples:
  advocate classify ~/Downloads/ --auto-rename
  advocate session restore
  advocate config set FEATURE_PDF_VISION=true
"""

import os
import sys
import json
import argparse
from pathlib import Path
from datetime import datetime
import subprocess

# Paths
HOME = Path.home()
ADVOCATE_DIR = HOME / ".advocate"
SESSION_FILE = ADVOCATE_DIR / "session.json"
CONFIG_FILE = ADVOCATE_DIR / "config.json"
SCRIPT_DIR = Path(__file__).parent / "scripts"
CLASSIFIER_SCRIPT = SCRIPT_DIR / "pdf_classifier_multi_provider.py"

# Ensure .advocate directory exists
ADVOCATE_DIR.mkdir(exist_ok=True)

def load_session():
    """Load session state from ~/.advocate/session.json"""
    if not SESSION_FILE.exists():
        return {
            "last_case": "26CV007491-590",
            "last_classification": None,
            "document_count": 0,
            "api_usage": {
                "classify_calls": 0,
                "last_month_cost": 0.0
            },
            "trials": {
                "trial_1": {"date": "2026-03-03", "case": "26CV005596-590"},
                "trial_2": {"date": "2026-03-10", "case": "26CV007491-590"}
            },
            "evidence_bundle_status": "incomplete"
        }
    
    with open(SESSION_FILE) as f:
        return json.load(f)

def save_session(session):
    """Save session state to ~/.advocate/session.json"""
    with open(SESSION_FILE, 'w') as f:
        json.dump(session, f, indent=2)

def load_config():
    """Load config from ~/.advocate/config.json"""
    if not CONFIG_FILE.exists():
        return {
            "FEATURE_PDF_VISION": "false",
            "ANTHROPIC_API_KEY": os.getenv("ANTHROPIC_API_KEY", ""),
            "OPENAI_API_KEY": os.getenv("OPENAI_API_KEY", ""),
            "GOOGLE_API_KEY": os.getenv("GOOGLE_API_KEY", "")
        }
    
    with open(CONFIG_FILE) as f:
        return json.load(f)

def save_config(config):
    """Save config to ~/.advocate/config.json"""
    with open(CONFIG_FILE, 'w') as f:
        json.dump(config, f, indent=2)

def classify_documents(path, auto_rename=False, vision_mode=False):
    """Classify documents using multi-provider PDF classifier"""
    session = load_session()
    config = load_config()
    
    # Set environment variables from config
    env = os.environ.copy()
    if vision_mode or config.get("FEATURE_PDF_VISION") == "true":
        env["FEATURE_PDF_VISION"] = "true"
    
    # Run classifier
    cmd = [sys.executable, str(CLASSIFIER_SCRIPT), str(path)]
    if auto_rename:
        cmd.append("--auto-rename")
    
    print(f"🔍 Classifying documents in {path}...")
    result = subprocess.run(cmd, env=env, capture_output=True, text=True)
    
    if result.returncode != 0:
        print(f"❌ Classification failed: {result.stderr}")
        return
    
    # Update session
    session["last_classification"] = datetime.now().isoformat()
    session["api_usage"]["classify_calls"] += 1
    session["document_count"] += result.stdout.count("Classified:")
    save_session(session)
    
    print(result.stdout)
    print(f"\n✅ Session updated: {session['document_count']} documents classified")

def session_restore(latest=False):
    """Restore session context"""
    session = load_session()
    
    print("📋 Advocate Session Context\n")
    print(f"Last Case: {session['last_case']}")
    
    if session['last_classification']:
        last_class = datetime.fromisoformat(session['last_classification'])
        print(f"Last Classified: {last_class.strftime('%Y-%m-%d %H:%M')}")
    else:
        print("Last Classified: Never")
    
    print(f"Documents Classified: {session['document_count']}")
    print(f"API Calls This Month: {session['api_usage']['classify_calls']}")
    
    # Calculate days until trials
    trial_1_date = datetime.strptime(session['trials']['trial_1']['date'], '%Y-%m-%d')
    trial_2_date = datetime.strptime(session['trials']['trial_2']['date'], '%Y-%m-%d')
    now = datetime.now()
    
    days_to_trial_1 = (trial_1_date - now).days
    days_to_trial_2 = (trial_2_date - now).days
    
    print(f"\n📅 Upcoming Trials:")
    print(f"  Trial #1 ({session['trials']['trial_1']['case']}): {days_to_trial_1} days")
    print(f"  Trial #2 ({session['trials']['trial_2']['case']}): {days_to_trial_2} days")
    print(f"\n📦 Evidence Bundle: {session['evidence_bundle_status']}")

def config_set(key_value):
    """Set config value"""
    config = load_config()
    
    if '=' not in key_value:
        print("❌ Usage: advocate config set KEY=VALUE")
        return
    
    key, value = key_value.split('=', 1)
    config[key] = value
    save_config(config)
    
    print(f"✅ Config updated: {key} = {value}")

def config_get(key):
    """Get config value"""
    config = load_config()
    value = config.get(key, "(not set)")
    print(f"{key} = {value}")

def main():
    parser = argparse.ArgumentParser(
        description="advocate - Legal Document Automation CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Commands')
    
    # classify command
    classify_parser = subparsers.add_parser('classify', help='Classify documents')
    classify_parser.add_argument('path', help='Path to classify')
    classify_parser.add_argument('--auto-rename', action='store_true', help='Auto-rename and organize')
    classify_parser.add_argument('--vision-mode', action='store_true', help='Use vision APIs')
    
    # session command
    session_parser = subparsers.add_parser('session', help='Session management')
    session_parser.add_argument('action', choices=['restore'], help='Session action')
    session_parser.add_argument('--latest', action='store_true', help='Show latest only')
    
    # config command
    config_parser = subparsers.add_parser('config', help='Configuration management')
    config_parser.add_argument('action', choices=['set', 'get'], help='Config action')
    config_parser.add_argument('key_or_pair', help='KEY for get, KEY=VALUE for set')
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        return
    
    if args.command == 'classify':
        classify_documents(args.path, args.auto_rename, args.vision_mode)
    elif args.command == 'session':
        if args.action == 'restore':
            session_restore(args.latest)
    elif args.command == 'config':
        if args.action == 'set':
            config_set(args.key_or_pair)
        elif args.action == 'get':
            config_get(args.key_or_pair)

if __name__ == '__main__':
    main()
