SPEC: SkillValidation.v1
GOAL: Persist skills from iteration N-1 and reuse them in N with dynamic scoring
ASSUMPTIONS:
  - skills_source == agentdb.skills AND file .ay-learning/available-skills-*.json
CONTRACT:
  preconditions:
    - exists(agentdb.skills)
    - exists(.ay-learning/available-skills-*.json)
  postconditions:
    - execute_mode.score == base_score * skill_confidence
    - skill_confidence in [0.5, 1.5]
EVIDENCE:
  - sqlite3 query: SELECT COUNT(*) FROM skills WHERE proficiency >= 0.7
  - file: .ay-learning/available-skills-orchestrator.json
SAFETY:
  - fallback: if skills missing, default confidence = 0.8
