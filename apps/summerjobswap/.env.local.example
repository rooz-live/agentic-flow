# Copy to .env.local and fill in real values
export SUMMERJOBSWAP_RELEASE_STORE_FILE=release.keystore
export SUMMERJOBSWAP_RELEASE_STORE_PASSWORD=CHANGE_ME
export SUMMERJOBSWAP_RELEASE_KEY_ALIAS=summerjobswap
export SUMMERJOBSWAP_RELEASE_KEY_PASSWORD=CHANGE_ME
export ANDROID_HOME=/Users/$USER/Library/Android/sdk
export JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-21.jdk/Contents/Home
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT=120
export FASTLANE_XCODE_BUILD_SETTINGS_TIMEOUT=120
# Optional: override iOS simulator destination
# export SUMMERJOBSWAP_IOS_SIM_DESTINATION="platform=iOS Simulator,name=iPhone 17 Pro,OS=26.5"
