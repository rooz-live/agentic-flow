#!/usr/bin/env bash
# AQE local wrapper - roll-forward pinned to v3.11.1

PROJECT_DIR="${PWD}"
export AQE_WORKING_DIR="${PROJECT_DIR}"

# Pin to the project-approved v3.11.1 release to avoid drift.
# This bypasses any broken global x86_64 install on arm64 machines.
exec npx --yes agentic-qe@3.11.1 "$@"
