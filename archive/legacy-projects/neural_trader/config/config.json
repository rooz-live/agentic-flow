{
  "data_sources": {
    "market_data": "alpaca",
    "sentiment_data": "twitter/discord"
  },
  "backtesting": {
    "framework": "backtrader",
    "initial_cash": 100000,
    "commission": 0.001
  },
  "risk_management": {
    "max_drawdown": 0.15,
    "max_leverage": 1.0,
    "stop_loss_pct": 0.02
  },
  "apra": {
    "enabled": true,
    "confidence_threshold": 0.75,
    "model_path": "models/checkpoints/apra_v1.pt"
  }
}