#!/usr/bin/env bash
# AGENT_SLICE=publication — install: cp code/tooling/scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
if [[ -x "$ROOT/scripts/hooks/pre-commit.template" ]]; then
  exec "$ROOT/scripts/hooks/pre-commit.template"
fi
if [[ -f "$ROOT/.git/hooks/pre-commit" ]] && [[ "$(readlink -f "$0" 2>/dev/null)" != "$(readlink -f "$ROOT/.git/hooks/pre-commit" 2>/dev/null)" ]]; then
  exec "$ROOT/.git/hooks/pre-commit"
fi
echo "pre-commit: no template found" >&2
exit 1
