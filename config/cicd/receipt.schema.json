{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentics.org/cicd/receipt.schema.json",
  "title": "CICD Run Receipt",
  "description": "Standard receipt for fetch-run-report cycles across upstream, local, edge, and orchestration contexts.",
  "type": "object",
  "required": [
    "receipt_id",
    "schema",
    "timestamp",
    "context",
    "status",
    "run"
  ],
  "properties": {
    "receipt_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this receipt."
    },
    "schema": {
      "type": "string",
      "const": "cicd.receipt.v1",
      "description": "Schema discriminator."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp when the receipt was produced."
    },
    "context": {
      "type": "string",
      "enum": [
        "upstream",
        "local",
        "edge",
        "orchestration",
        "scorecard",
        "hire"
      ],
      "description": "Bounded context that produced the receipt."
    },
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL",
        "BLOCK",
        "SKIP",
        "TIMEOUT"
      ],
      "description": "Coarse outcome of the run."
    },
    "run": {
      "type": "object",
      "required": [
        "command",
        "exit_code"
      ],
      "properties": {
        "command": {
          "type": "string",
          "description": "The command that was executed."
        },
        "exit_code": {
          "type": "integer",
          "description": "Process exit code."
        },
        "stdout": {
          "type": "string",
          "description": "Captured standard output (truncated is acceptable)."
        },
        "stderr": {
          "type": "string",
          "description": "Captured standard error (truncated is acceptable)."
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0,
          "description": "Elapsed wall time."
        }
      }
    },
    "signals": {
      "type": "array",
      "description": "Verifiable signals captured during the run.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "ok"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          },
          "required": {
            "type": "boolean",
            "default": true
          },
          "details": {
            "type": "object"
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "meta": {
      "type": "object",
      "description": "Context-specific metadata.",
      "properties": {
        "commit": {
          "type": "string"
        },
        "diff_sha256": {
          "type": "string"
        },
        "roam_risk_id": {
          "type": "string"
        },
        "repo_url": {
          "type": "string"
        },
        "receipt_path": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": false
}
