      "run_timeout_s": 180,
      "retry": 1,
      "notify_on_fail": true,
      "roam_risk_id": "R-CLS-05",
      "dor_cmd": null
    },
    {
      "id": "billing-platform",
      "url": "https://github.com/bhopti/billing-platform",
      "branch": "main",
      "integration_test": "python3 -m pytest tests/billing/ -q --tb=line",
      "active": false,
      "timeout_s": 20,
