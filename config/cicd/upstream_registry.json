  "repositories": [
    {
      "id": "opik",
      "url": "https://github.com/comet-ml/opik",
      "branch": "main",
      "integration_test": "python3 -c 'import sys; sys.exit(0)'",
      "active": true,
      "timeout_s": 15,
      "run_timeout_s": 30,
      "retry": 1,
      "notify_on_fail": true,
      "roam_risk_id": null,
      "dor_cmd": null
    },
    {
      "id": "mcp",
      "url": "https://github.com/google/mcp",
      "branch": "main",
      "integration_test": "npx playwright test --list",
      "active": true,
      "timeout_s": 20,
      "run_timeout_s": 60,
      "retry": 1,
      "notify_on_fail": true,
      "roam_risk_id": null,
      "dor_cmd": null
    },
    {
      "id": "ruflo",
      "url": "https://github.com/ruvnet/ruflo",
      "branch": "main",
      "integration_test": "cargo check",
      "active": true,
      "timeout_s": 20,
      "run_timeout_s": 120,
      "retry": 2,
      "notify_on_fail": true,
