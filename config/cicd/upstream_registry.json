{
  "upgrades_configuration": {
    "auto_pull_latest": true,
    "enforce_tdd_before_merge": true,
    "evidence_output_directory": ".goalie/evidence/upgrades",
    "parallel_fetch": true,
    "default_timeout_s": 20,
    "default_run_timeout_s": 120,
    "default_retry": 1,
    "log_truncate_bytes": 8192
