# Discord Bot Production Environment Configuration
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production to version control

# Discord Application Configuration
# Obtain from: https://discord.com/developers/applications
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=               # OAuth token for bot authentication

# Optional: Guild ID for guild-scoped command testing (faster propagation)
DISCORD_GUILD_ID=

# Discord Admin Configuration
DISCORD_ADMIN_ROLE_ID=           # Role ID for admin commands

# Cloudflare Workers Configuration
# Obtain from: https://dash.cloudflare.com
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=            # Scope: Workers R/W, KV namespace R/W if used
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_PROJECT_NAME=discord-trading-bot
CLOUDFLARE_ROUTE=https://go.rooz.live/api/discord/*

# Stripe Integration
# Separate test vs production keys
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Financial Data Providers
# Choose one provider per data type and obtain API key
DATA_EARNINGS_PROVIDER=fmp       # Options: fmp (FinancialModelingPrep), polygon, finnhub
DATA_EARNINGS_API_KEY=

DATA_ANALYST_PROVIDER=finnhub    # Options: yd (YahooFinance), finnhub, tipranks
DATA_ANALYST_API_KEY=

DATA_MARKET_PROVIDER=polygon     # For real-time quotes and historical data
DATA_MARKET_API_KEY=

# Rate Limiting Configuration
RATE_LIMIT_RPM=60                # Requests per minute per user
RATE_LIMIT_BURST=10              # Maximum burst requests

# Operational Configuration
LOG_LEVEL=info                   # Options: debug, info, warn, error
ENVIRONMENT=production           # Options: development, staging, production

# Health Check Configuration
HEALTH_CHECK_INTERVAL=60         # Seconds between health checks
HEALTH_CHECK_TIMEOUT=5           # Timeout for health checks in seconds

# Message Persistence (if using D1 or KV)
ENABLE_MESSAGE_PERSISTENCE=false # Set to true to enable message logging
MESSAGE_RETENTION_DAYS=90        # Days to retain message logs

# Feature Flags
ENABLE_PORTFOLIO_COMMANDS=true
ENABLE_TRADING_ALERTS=true
ENABLE_EARNINGS_NOTIFICATIONS=true
ENABLE_ANALYTICS=true

# External Integrations
WEBHOOK_URL_ROOZ=https://go.rooz.live/webhooks/discord
WEBHOOK_URL_DECISION=https://decisioncall.com/webhooks/discord

# Security Notes:
# 1. Never commit actual credentials to version control
# 2. Use Cloudflare Workers Secrets for sensitive values in production
# 3. Rotate credentials regularly
# 4. Validate CLOUDFLARE_API_TOKEN has minimal required scopes
# 5. Keep test and production environments completely separate
