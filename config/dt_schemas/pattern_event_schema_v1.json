{
  "$schema": "1.0",
  "title": "Pattern Event Schema v1",
  "description": "JSON Schema for pattern metrics events in the agentic-flow governance pipeline",
  "type": "object",
  "required": [
    "ts", "run", "run_id", "iteration", "circle", "depth",
    "pattern", "mode", "mutation", "gate", "framework",
    "scheduler", "tags", "economic", "reason", "action", "prod_mode"
  ],
  "properties": {
    "ts": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp" },
    "run": { "type": "string", "description": "Run name (e.g. prod-cycle, full-cycle)" },
    "run_id": { "type": "string", "description": "Unique run identifier" },
    "iteration": { "type": "integer", "minimum": 1, "description": "Iteration number" },
    "circle": {
      "type": "string",
      "enum": ["analyst", "assessor", "innovator", "intuitive", "architect", "orchestrator"]
    },
    "depth": { "type": "integer", "minimum": 1, "maximum": 4 },
    "pattern": { "type": "string", "description": "Pattern name" },
    "mode": { "type": "string", "enum": ["advisory", "enforcement", "mutation"] },
    "mutation": { "type": "boolean" },
    "gate": { "type": "string", "description": "Gate identifier" },
    "framework": { "type": "string", "description": "Framework identifier" },
    "scheduler": { "type": "string", "description": "Scheduler identifier" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "economic": {
      "type": "object",
      "properties": {
        "cod": { "type": "number", "minimum": 0, "description": "Cost of Delay" },
        "wsjf_score": { "type": "number", "minimum": 0, "description": "WSJF score" },
        "user_value": { "type": "number" },
        "time_criticality": { "type": "number" },
        "risk_reduction": { "type": "number" },
        "job_size": { "type": "number", "minimum": 1 }
      },
      "required": ["cod", "wsjf_score"]
    },
    "reason": { "type": "string" },
    "action": { "type": "string" },
    "prod_mode": { "type": "boolean" },
    "data": { "type": "object", "description": "Pattern-specific payload" },
    "metrics": { "type": "object", "description": "Pattern-specific metrics" },
    "tenant_id": { "type": "string" },
    "tenant_platform": { "type": "string" }
  },
  "additionalProperties": true
}
