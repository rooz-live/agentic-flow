# Copy to config/local/llm-paths.env (gitignored) and source from shell rc.
# Echo 13 SSD — canonical local LLM model disk for this workspace.

export LM_STUDIO_DIR="/Volumes/Echo 13 SSD/LLM-Models/lmstudio"
export OLLAMA_MODELS="/Volumes/Echo 13 SSD/LLM-Models/ollama"
export HF_HOME="/Volumes/Echo 13 SSD/LLM-Models/huggingface"
export CENTRAL_MODELS_DIR="${HOME}/.local/share/universal-models"

# Optional: Windsurf/Cursor Codeium models (symlink once)
# ln -sf "/Volumes/Echo 13 SSD/LLM-Models/codeium" "${HOME}/.codeium"

# After paths are set:
# bash scripts/system/sync-universal-models.sh
