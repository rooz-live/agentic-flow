{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "inbox_zero_timescape",
  "schema_version": "1.0.0",
  "type": "object",
  "required": [
    "schema_version",
    "timestamp",
    "pct_closed",
    "open_count",
    "velocity",
    "pace",
    "anti_cvt",
    "window_hours",
    "head_sha",
    "emergent_time_source",
    "details"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "pct_closed": { "type": "number", "minimum": 0, "maximum": 100 },
    "open_count": { "type": "integer", "minimum": 0 },
    "velocity": { "type": "number", "minimum": 0 },
    "pace": { "type": "number" },
    "anti_cvt": { "type": "integer", "minimum": 0 },
    "window_hours": { "type": "number", "exclusiveMinimum": 0 },
    "head_sha": { "type": "string" },
    "emergent_time_source": { "type": "string", "enum": ["wall_clock"] },
    "details": { "type": "object" }
  },
  "additionalProperties": true
}
