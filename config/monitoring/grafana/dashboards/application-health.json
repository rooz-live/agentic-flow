              "namespace": true,
              "node": true,
              "pod_ip": true,
              "priority_class": true,
              "qos_class": true,
              "service": true,
              "uid": true
            },
            "indexByName": {
              "pod": 0,
              "phase": 1,
              "Value #B": 2,
              "Value #D": 3
            },
            "renameByName": {
              "Value #B": "Restarts (1h)",
              "Value #C": "",
              "Value #D": "Ready",
              "phase": "Status",
              "pod": "Pod Name"
            }
          }
        }
      ],
      "type": "table"
