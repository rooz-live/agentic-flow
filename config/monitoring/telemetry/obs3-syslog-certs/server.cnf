[ req ]
default_bits = 4096
distinguished_name = req_distinguished_name
req_extensions = req_ext
string_mask = utf8only
default_md = sha384
prompt = no

[ req_distinguished_name ]
C = US
ST = California
L = San Francisco
O = Interface Tag
OU = Syslog Infrastructure
CN = syslog-sink.internal

[ req_ext ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = syslog-sink.internal
DNS.2 = stx-aio-0.corp.interface.tag.ooo
IP.1 = 23.92.79.2
