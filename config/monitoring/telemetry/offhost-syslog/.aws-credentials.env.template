# AWS Credentials
# IMPORTANT: Copy this file to ~/.aws-credentials.env and fill in actual values
# DO NOT commit this file with real credentials!

AWS_ACCESS_KEY_ID=your_actual_aws_access_key
AWS_SECRET_ACCESS_KEY=your_actual_aws_secret_key
AWS_REGION=us-east-1

# Instructions:
# 1. cp config/telemetry/offhost-syslog/.aws-credentials.env.template ~/.aws-credentials.env
# 2. Edit ~/.aws-credentials.env and replace placeholder values with actual credentials
# 3. chmod 600 ~/.aws-credentials.env
# 4. Source the file: source ~/.aws-credentials.env
