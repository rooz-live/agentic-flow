# =============================================================================
# Off-Host Syslog Infrastructure - Git Ignore
# =============================================================================
# Purpose: Prevent sensitive files from being committed to version control
# Security: Non-negotiable - secrets must never be in git
# =============================================================================

# =============================================================================
# TLS Certificates and Keys (CRITICAL)
# =============================================================================

# All private keys - NEVER commit
*.key
*.pem
**/private/
**/secrets/

# Generated certificate directory
certs/generated/
tls/generated/

# Certificate signing requests (contain identifying info)
*.csr

# Serialized private keys
*.p12
*.pfx
*.pkcs12

# SSH keys
id_rsa*
id_ed25519*
id_ecdsa*
*.pub

# =============================================================================
# Terraform State and Secrets
# =============================================================================

# Terraform state files (contain secrets)
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Terraform variable files with secrets
*.auto.tfvars
*.auto.tfvars.json
terraform.tfvars
terraform.tfvars.json
secrets.tfvars

# Terraform crash logs
crash.log
crash.*.log

# Terraform plan output (may contain secrets)
*.tfplan
plan.out

# =============================================================================
# Ansible Secrets
# =============================================================================

# Ansible vault encrypted files (even though encrypted, keep out of public repos)
*vault*.yml
*vault*.yaml
vault.yml
vault.yaml

# Ansible vault password files
.vault_pass
.vault_password
vault_password_file
*.vault_pass

# Ansible inventory with real IPs/hostnames
inventory/production.yml
inventory/production.ini
inventory/hosts.ini
!inventory/hosts.yml.example

# Ansible variable files with secrets
group_vars/all/secrets.yml
group_vars/*/vault.yml
host_vars/*/vault.yml

# =============================================================================
# Environment and Configuration Files
# =============================================================================

# Environment files
.env
.env.*
!.env.example
!.env.template

# Configuration with secrets
config.json
secrets.json
credentials.json
service-account.json

# AWS credentials
.aws/
credentials

# =============================================================================
# Logs and Runtime Data
# =============================================================================

# Log files
*.log
logs/
*.log.*

# Runtime directories
tmp/
temp/
cache/

# PID files
*.pid

# =============================================================================
# IDE and Editor
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# =============================================================================
# Build and Test Artifacts
# =============================================================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.eggs/
*.egg
venv/
.venv/

# Coverage
coverage/
.coverage
htmlcov/

# =============================================================================
# Backup Files
# =============================================================================

# Backup files
*.bak
*.backup
*.old
*~

# Archive files (may contain secrets)
*.tar.gz
*.zip
*.7z

# =============================================================================
# Security Scanning Results
# =============================================================================

# Security scan output
security-report.json
vulnerability-report.json
trivy-results.json
grype-results.json

# =============================================================================
# Notes
# =============================================================================
# 
# IMPORTANT: Review this file regularly
# 
# Before committing, always run:
#   git status
#   git diff --cached
#
# To check for secrets:
#   grep -r "BEGIN PRIVATE KEY" .
#   grep -r "BEGIN RSA PRIVATE KEY" .
#   grep -r "password" . | grep -v ".gitignore"
#
# Use git-secrets or similar tools to prevent accidental commits:
#   git secrets --install
#   git secrets --register-aws
#
# =============================================================================
