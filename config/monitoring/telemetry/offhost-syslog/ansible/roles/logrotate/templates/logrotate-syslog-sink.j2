# =============================================================================
# Logrotate Configuration - Off-Host Syslog Sink
# =============================================================================
# Generated by Ansible
# Purpose: Manage log retention for remote syslog files
# =============================================================================

# =============================================================================
# Auth Log - 30-day retention
# =============================================================================
# Contains: SSH logins, sudo usage, PAM events, authentication failures
# Path: {{ auth_log_path }}

{{ auth_log_path }} {
    daily
    rotate {{ auth_log_retention_days }}
    compress
    delaycompress
    missingok
    notifempty
    create 0640 syslog adm
    sharedscripts
    postrotate
        # Reload rsyslog to pick up new log file
        systemctl reload rsyslog > /dev/null 2>&1 || true
    endscript
}

# =============================================================================
# System Log - 7-day retention
# =============================================================================
# Contains: Warnings, errors, critical events (excluding authpriv)
# Path: {{ system_log_path }}

{{ system_log_path }} {
    daily
    rotate {{ system_log_retention_days }}
    compress
    delaycompress
    missingok
    notifempty
    create 0640 syslog adm
    sharedscripts
    postrotate
        # Reload rsyslog to pick up new log file
        systemctl reload rsyslog > /dev/null 2>&1 || true
    endscript
}

# =============================================================================
# Configuration Notes:
# =============================================================================
#
# daily:         Rotate logs daily
# rotate N:      Keep N rotated files
# compress:      Compress rotated files with gzip
# delaycompress: Don't compress most recent rotated file (easier debugging)
# missingok:     Don't error if log file is missing
# notifempty:    Don't rotate empty files
# create:        Create new log file with specified permissions
# sharedscripts: Run postrotate once, not for each log file
# postrotate:    Reload rsyslog after rotation
#
# =============================================================================
