# =============================================================================
# rsyslog Message Filters and Routing Rules
# =============================================================================
# Generated by Ansible - Off-Host Syslog Black Box Recorder
# Purpose: Route messages to appropriate log files
# =============================================================================

# =============================================================================
# Log Stream: Auth (authpriv.* + sudo)
# Path: {{ auth_log_path }}
# Retention: {{ auth_log_retention_days }} days
# =============================================================================

# Capture all authpriv messages (SSH, PAM, authentication)
if $syslogfacility-text == 'authpriv' then {
    action(
        type="omfile"
        file="{{ auth_log_path }}"
        fileOwner="syslog"
        fileGroup="adm"
        fileCreateMode="0640"
        dirCreateMode="0750"
    )
    stop
}

# Capture sudo messages (may come from other facilities)
if $programname == 'sudo' then {
    action(
        type="omfile"
        file="{{ auth_log_path }}"
        fileOwner="syslog"
        fileGroup="adm"
        fileCreateMode="0640"
        dirCreateMode="0750"
    )
    stop
}

# Capture sshd messages (for redundancy)
if $programname == 'sshd' then {
    action(
        type="omfile"
        file="{{ auth_log_path }}"
        fileOwner="syslog"
        fileGroup="adm"
        fileCreateMode="0640"
        dirCreateMode="0750"
    )
    stop
}

# =============================================================================
# Log Stream: System (*.warn and above, excluding authpriv)
# Path: {{ system_log_path }}
# Retention: {{ system_log_retention_days }} days
# =============================================================================

# Capture warnings and above, excluding authpriv (already captured)
# Severity <= 4 = warning(4), error(3), critical(2), alert(1), emergency(0)
if ($syslogseverity <= 4) and ($syslogfacility-text != 'authpriv') then {
    action(
        type="omfile"
        file="{{ system_log_path }}"
        fileOwner="syslog"
        fileGroup="adm"
        fileCreateMode="0640"
        dirCreateMode="0750"
    )
    stop
}

# =============================================================================
# Discard remaining messages
# =============================================================================
# We only want authpriv/sudo and warnings+
# All other messages are discarded to save disk space

& stop

# =============================================================================
# Notes:
# - Auth stream captures: SSH logins, sudo usage, PAM events, authentication
# - System stream captures: warnings, errors, critical events (non-auth)
# - Lower severity (info, debug) messages are discarded
# - Logrotate handles retention (30 days auth, 7 days system)
# =============================================================================
