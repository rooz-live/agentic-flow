# =============================================================================
# rsyslog TLS Server Configuration
# =============================================================================
# Generated by Ansible - Off-Host Syslog Black Box Recorder
# Purpose: Listen for TLS-encrypted syslog on TCP/6514
# =============================================================================

# Load required modules
module(load="imtcp")       # TCP input module
module(load="omfile")      # File output module

# GnuTLS driver for TLS
global(
    defaultNetstreamDriver="gtls"
    defaultNetstreamDriverCAFile="{{ ca_cert_path }}"
    defaultNetstreamDriverCertFile="{{ server_cert_path }}"
    defaultNetstreamDriverKeyFile="{{ server_key_path }}"
)

# Global settings
$WorkDirectory /var/spool/rsyslog
$IncludeConfig /etc/rsyslog.d/*.conf

# Main message queue configuration
main_queue(
    queue.filename="main_q"
    queue.maxdiskspace="1g"
    queue.saveonshutdown="on"
    queue.type="LinkedList"
)

# =============================================================================
# TLS Input on Port {{ syslog_port }}
# =============================================================================
# - Requires client certificate (mutual TLS)
# - Only accepts connections from permitted peer CN
# - TLS 1.2+ enforced by GnuTLS driver

input(
    type="imtcp"
    port="{{ syslog_port }}"
    name="tls_input"
    
    # TLS Configuration
    streamdriver="gtls"
    streamdriver.mode="1"
    streamdriver.authmode="x509/name"
    permittedpeer=["stx-aio-0.corp.interface.tag.ooo"]
    
    # Rate limiting (messages per second)
    ratelimit.interval="1"
    ratelimit.burst="10000"
)

# =============================================================================
# Notes:
# - Server listens on TCP/{{ syslog_port }} with TLS
# - Only stx-aio-0.corp.interface.tag.ooo is permitted to connect
# - Client must present a valid certificate signed by our CA
# - Message routing rules are in 98-filters.conf
# =============================================================================
