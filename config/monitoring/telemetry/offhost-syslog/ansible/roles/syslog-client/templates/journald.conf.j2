# Journald Configuration - Off-Host Syslog Black Box Recorder
# Forward journald logs to rsyslog

[Journal]
# Maximum size of the journal file
SystemMaxUse=1G

# Maximum retention time
MaxRetentionSec=30day

# Forward to syslog
ForwardToSyslog=yes

# Rate limiting for noisy logs
RateLimitIntervalSec=30s
RateLimitBurst=10000

# Storage configuration
Storage=auto

# Compress journal files
Compress=yes

# Sync to disk
SyncIntervalSec=5m
