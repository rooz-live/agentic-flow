# Logrotate configuration for Auth/Sudo logs
# Managed by Ansible - Do not edit manually
# Retention: {{ auth_retention_days }} days

{{ log_dir }}/auth.log {
    daily
    rotate {{ auth_retention_days }}
    compress
    delaycompress
    missingok
    notifempty
    create 0640 syslog adm
    sharedscripts
    postrotate
        /usr/lib/rsyslog/rsyslog-rotate
    endscript
}

