# Logrotate Configuration for Remote Syslog
# Deployed via Ansible - DO NOT EDIT MANUALLY
#
# Log Retention Policy:
#   - Auth logs: {{ auth_retention_days }} days
#   - System logs: {{ system_retention_days }} days

# Auth/Sudo logs - 30-day retention
{{ remote_log_dir }}/auth.log {
    daily
    rotate {{ auth_retention_days }}
    compress
    delaycompress
    missingok
    notifempty
    create 0640 syslog adm
    postrotate
        /usr/lib/rsyslog/rsyslog-rotate
    endscript
}

# System warning logs - 7-day retention
{{ remote_log_dir }}/system.log {
    daily
    rotate {{ system_retention_days }}
    compress
    delaycompress
    missingok
    notifempty
    create 0640 syslog adm
    postrotate
        /usr/lib/rsyslog/rsyslog-rotate
    endscript
}
