# Logrotate configuration for System warning/error logs
# Managed by Ansible - Do not edit manually
# Retention: {{ system_retention_days }} days

{{ log_dir }}/system.log {
    daily
    rotate {{ system_retention_days }}
    compress
    delaycompress
    missingok
    notifempty
    create 0640 syslog adm
    sharedscripts
    postrotate
        /usr/lib/rsyslog/rsyslog-rotate
    endscript
}

