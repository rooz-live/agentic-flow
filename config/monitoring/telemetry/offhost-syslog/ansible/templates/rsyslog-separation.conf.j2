# Log Separation Configuration for Off-Host Syslog Sink
# Managed by Ansible - Do not edit manually
#
# Log Streams:
# 1. Auth/Sudo: authpriv + sudo program messages -> 30-day retention
# 2. System warnings/errors: *.warn (excluding authpriv) -> 7-day retention

# ============================================================================
# Auth/Sudo Stream (30-day retention)
# ============================================================================

# Capture authpriv facility
authpriv.*  {{ log_dir }}/auth.log

# Capture sudo program messages
:programname, isequal, "sudo"  {{ log_dir }}/auth.log

# ============================================================================
# System Warnings/Errors Stream (7-day retention)
# ============================================================================

# Capture *.warn and above, excluding authpriv to avoid duplicates
if $syslogfacility-text != 'authpriv' and $syslogseverity <= 4 then {
    action(type="omfile" file="{{ log_dir }}/system.log")
}

# ============================================================================
# Discard Messages After Processing
# ============================================================================

# Stop processing after matching rules above
# This prevents duplicate logging to default syslog locations
& stop

