# Rsyslog TLS Configuration for Syslog Sink
# Managed by Ansible - Do not edit manually
#
# Receives syslog over TLS on port 6514
# Requires mutual TLS authentication

# Load TLS module
module(load="imtcp"
       StreamDriver.Name="gtls"
       StreamDriver.Mode="1"
       StreamDriver.AuthMode="x509/name")

# TLS Certificate Configuration
global(
    DefaultNetstreamDriver="gtls"
    DefaultNetstreamDriverCAFile="{{ tls_dir }}/ca.crt"
    DefaultNetstreamDriverCertFile="{{ tls_dir }}/server.crt"
    DefaultNetstreamDriverKeyFile="{{ tls_dir }}/server.key"
)

# TLS Input on port 6514
# Only accept connections from authenticated clients
input(type="imtcp"
      port="6514"
      StreamDriver.Name="gtls"
      StreamDriver.Mode="1"
      StreamDriver.AuthMode="x509/name"
      PermittedPeer=["stx-aio-0"]
)

