{
  "$schema": "https://raw.githubusercontent.com/flarum/framework/main/extensions/oauth/config-schema.json",
  "_comment": "Flarum OAuth Configuration for fof/oauth extension",
  "_risk_id": "RISK-005",
  "_documentation": "https://github.com/FriendsOfFlarum/oauth",
  
  "fof-oauth": {
    "providers": {
      "custom": {
        "enabled": true,
        "name": "Interface Identity",
        "icon": "fas fa-shield-alt",
        "driver": "generic",
        "settings": {
          "client_id": "${FLARUM_OAUTH_CLIENT_ID:-flarum-forum}",
          "client_secret": "${FLARUM_OAUTH_CLIENT_SECRET}",
          "authorize_url": "https://auth.interface.tag.ooo/realms/interface/protocol/openid-connect/auth",
          "token_url": "https://auth.interface.tag.ooo/realms/interface/protocol/openid-connect/token",
          "userinfo_url": "https://auth.interface.tag.ooo/realms/interface/protocol/openid-connect/userinfo",
          "scopes": ["openid", "email", "profile"],
          "pkce": true,
          "pkce_method": "S256",
          "id_path": "sub",
          "email_path": "email",
          "username_path": "preferred_username",
          "name_path": "name",
          "avatar_path": null
        }
      }
    },
    "only_social_login": false,
    "logoutUrl": "https://auth.interface.tag.ooo/realms/interface/protocol/openid-connect/logout?post_logout_redirect_uri=https://forum.interface.tag.ooo"
  },
  
  "_installation_steps": [
    "1. Install extension: composer require fof/oauth",
    "2. Enable in admin panel: Extensions -> FoF OAuth",
    "3. Configure custom provider with these settings",
    "4. Set environment variables for client_id and client_secret",
    "5. Test login flow at: https://forum.interface.tag.ooo/login"
  ],
  
  "_role_mapping": {
    "description": "Map Keycloak roles to Flarum groups",
    "admin": "admin",
    "enterprise_admin": "moderator",
    "enterprise_user": "member",
    "user": "member"
  },
  
  "_cross_domain_session": {
    "cookie_domain": ".interface.tag.ooo",
    "session_name": "interface_sso_session",
    "secure": true,
    "httponly": true,
    "samesite": "lax"
  },
  
  "_validation_commands": {
    "check_extension": "composer show fof/oauth",
    "test_auth_endpoint": "curl -s https://auth.interface.tag.ooo/realms/interface/.well-known/openid-configuration | jq '.authorization_endpoint'",
    "test_token_endpoint": "curl -s https://auth.interface.tag.ooo/realms/interface/.well-known/openid-configuration | jq '.token_endpoint'"
  }
}

