# Keycloak Configuration
# Copy to .env and fill in production values

# Admin credentials - CHANGE IN PRODUCTION
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=your_secure_admin_password_here

# Database configuration
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=your_secure_db_password_here

# Redis configuration
REDIS_PASSWORD=your_secure_redis_password_here

# OAuth Client Secrets - Generate with: openssl rand -base64 32
WORDPRESS_OAUTH_CLIENT_SECRET=generate_with_openssl_rand_base64_32
FLARUM_OAUTH_CLIENT_SECRET=generate_with_openssl_rand_base64_32
HOSTBILL_OAUTH_CLIENT_SECRET=generate_with_openssl_rand_base64_32

# Domain configuration
SSO_DOMAIN=auth.interface.tag.ooo
COOKIE_DOMAIN=.interface.tag.ooo

