{
  "realm": "interface",
  "enabled": true,
  "displayName": "Interface Identity",
  "displayNameHtml": "<div class=\"kc-logo-text\"><span>Interface Identity</span></div>",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 30,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Full admin access" },
      { "name": "enterprise_admin", "description": "Enterprise tier admin" },
      { "name": "enterprise_user", "description": "Enterprise tier user" },
      { "name": "analyst", "description": "Analytics access" },
      { "name": "risk_manager", "description": "Risk dashboard access" },
      { "name": "affiliate", "description": "Affiliate portal access" },
      { "name": "user", "description": "Standard user access" }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "interface-app",
      "name": "Interface App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "rootUrl": "https://app.interface.tag.ooo",
      "baseUrl": "/",
      "redirectUris": ["https://app.interface.tag.ooo/*"],
      "webOrigins": ["https://app.interface.tag.ooo"],
      "protocol": "openid-connect",
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "wordpress-blog",
      "name": "WordPress Blog",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "rootUrl": "https://blog.interface.tag.ooo",
      "redirectUris": ["https://blog.interface.tag.ooo/wp-login.php?loginSocial=oauth2"],
      "webOrigins": ["https://blog.interface.tag.ooo"],
      "protocol": "openid-connect",
      "secret": "${WORDPRESS_OAUTH_CLIENT_SECRET}"
    },
    {
      "clientId": "flarum-forum",
      "name": "Flarum Forum",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "rootUrl": "https://forum.interface.tag.ooo",
      "redirectUris": ["https://forum.interface.tag.ooo/auth/oauth"],
      "webOrigins": ["https://forum.interface.tag.ooo"],
      "protocol": "openid-connect",
      "secret": "${FLARUM_OAUTH_CLIENT_SECRET}"
    },
    {
      "clientId": "hostbill-billing",
      "name": "HostBill Billing",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": true,
      "rootUrl": "https://billing.interface.tag.ooo",
      "redirectUris": ["https://billing.interface.tag.ooo/oauth/callback"],
      "webOrigins": ["https://billing.interface.tag.ooo"],
      "protocol": "openid-connect",
      "secret": "${HOSTBILL_OAUTH_CLIENT_SECRET}"
    },
    {
      "clientId": "enterprise-portal",
      "name": "Enterprise Portal",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "rootUrl": "https://enterprise.interface.tag.ooo",
      "redirectUris": ["https://enterprise.interface.tag.ooo/*"],
      "webOrigins": ["https://enterprise.interface.tag.ooo"],
      "protocol": "openid-connect",
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "analytics-dashboard",
      "name": "Analytics Dashboard",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "rootUrl": "https://analytics.interface.tag.ooo",
      "redirectUris": ["https://analytics.interface.tag.ooo/*"],
      "webOrigins": ["https://analytics.interface.tag.ooo"],
      "protocol": "openid-connect",
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "risk-dashboard",
      "name": "Risk Dashboard",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "rootUrl": "https://risk.interface.tag.ooo",
      "redirectUris": ["https://risk.interface.tag.ooo/*"],
      "webOrigins": ["https://risk.interface.tag.ooo"],
      "protocol": "openid-connect",
      "attributes": { "pkce.code.challenge.method": "S256" }
    }
  ],
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 86400,
  "offlineSessionIdleTimeout": 604800,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300
}

