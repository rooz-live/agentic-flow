{{ syslog_log_dir }}/auth.log {
  daily
  rotate 30
  missingok
  notifempty
  compress
  delaycompress
  copytruncate
  create 0640 root adm
  sharedscripts
  postrotate
    systemctl reload rsyslog >/dev/null 2>&1 || true
  endscript
}

