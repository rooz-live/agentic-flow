[Unit]
Description=Agentic Flow Affiliate API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/agentic-flow
Environment="PYTHONPATH=/opt/agentic-flow"
ExecStart=/usr/bin/python3 scripts/agentic/affiliate_platform.py daemon
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
