# Agentic Flow - Multi-Model Configuration Template
# Run multiple model providers simultaneously
# Deploy multiple services with different configurations

# === Service 1: Claude (Premium Quality) ===
# Use for complex reasoning, code reviews, architecture
CLAUDE_MODEL_PROVIDER=
CLAUDE_MODEL_NAME=
CLAUDE_ANTHROPIC_API_KEY=
CLAUDE_PORT=

# === Service 2: OpenRouter/Llama (Cost-Effective) ===
# Use for simple tasks, research, documentation
OPENROUTER_MODEL_PROVIDER=
OPENROUTER_MODEL_NAME=
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
OPENROUTER_PORT=

# === Service 3: DeepSeek (Code Specialist) ===
# Use for code generation and analysis
DEEPSEEK_MODEL_PROVIDER=
DEEPSEEK_MODEL_NAME=
DEEPSEEK_OPENROUTER_API_KEY=
DEEPSEEK_PORT=

# === Service 4: ONNX (Fully Local) ===
# Use for offline/air-gapped environments
ONNX_MODEL_PROVIDER=
ONNX_MODEL_PATH=
ONNX_PORT=

# Shared Configuration
E2B_API_KEY=e2b_your_api_key_here
AGENTS_DIR=
ENABLE_LOGGING=
LOG_LEVEL="info  # debug, info, warn, error"
NODE_ENV="development  # development, staging, production"
MCP_AUTO_START=
ENABLE_MEMORY=
MEMORY_TTL=

# Load Balancing Strategy
# route_by_task: Choose provider based on task complexity
# round_robin: Distribute evenly
# cost_optimized: Prefer cheaper models
ROUTING_STRATEGY=

# Task Routing Rules
COMPLEX_TASKS_PROVIDER=
SIMPLE_TASKS_PROVIDER=
CODE_TASKS_PROVIDER=
OFFLINE_PROVIDER=


