{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-flow.dev/schemas/pattern-event.json",
  "title": "Pattern Event",
  "description": "Schema for pattern telemetry events in Agentic Flow continuous iterative improvement system",
  "type": "object",
  "required": [
    "ts",
    "run",
    "run_id",
    "iteration",
    "circle",
    "depth",
    "pattern",
    "pattern:kebab-name",
    "mode",
    "mutation",
    "gate",
    "framework",
    "scheduler",
    "tags",
    "economic",
    "reason",
    "action",
    "prod_mode"
  ],
  "properties": {
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event was emitted"
    },
    "run": {
      "type": "string",
      "description": "Run type identifier",
      "examples": ["prod-cycle", "full-cycle", "governance-agent", "retro-coach", "sample-workloads"]
    },
    "run_id": {
      "type": "string",
      "description": "Unique run identifier for tracking related events",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "iteration": {
      "type": "integer",
      "minimum": 0,
      "description": "Cycle iteration number (0-based)"
    },
    "circle": {
      "type": "string",
      "enum": ["analyst", "assessor", "innovator", "intuitive", "orchestrator", "seeker", "governance", "retro", "unknown"],
      "description": "Holacracy circle responsible for this event"
    },
    "depth": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4,
      "description": "Depth ladder level (0=surface, 4=deep architectural)"
    },
    "pattern": {
      "type": "string",
      "description": "Pattern name in kebab-case",
      "examples": [
        "safe-degrade",
        "guardrail-lock",
        "iteration-budget",
        "observability-first",
        "autocommit-shadow",
        "circle-risk-focus",
        "failure-strategy",
        "depth-ladder",
        "ml-training-guardrail",
        "hpc-batch-window",
        "stat-robustness-sweep",
        "device-coverage",
        "forensic-verification"
      ]
    },
    "pattern:kebab-name": {
      "type": "string",
      "description": "Pattern name in kebab-case (duplicate for compatibility)"
    },
    "mode": {
      "type": "string",
      "enum": ["advisory", "mutate", "enforcement"],
      "description": "Pattern execution mode"
    },
    "mutation": {
      "type": "boolean",
      "description": "Whether this event caused state mutation"
    },
    "gate": {
      "type": "string",
      "description": "Quality gate that triggered this pattern",
      "examples": [
        "health",
        "governance",
        "wsjf",
        "focus",
        "prod-cycle-gate",
        "governance-review",
        "retro-analysis",
        "observability",
        "circle-output"
      ]
    },
    "framework": {
      "type": "string",
      "description": "Technical framework context (empty string if not applicable)",
      "examples": ["torch", "tensorflow", "sklearn", "scipy", "react-native", "electron", "vite", ""]
    },
    "scheduler": {
      "type": "string",
      "description": "Workload scheduler context (empty string if not HPC)",
      "examples": ["slurm", "k8s", "kubernetes", "ray", "local", ""]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Federation", "ML", "HPC", "Stats", "Device/Web", "Observability", "Forensic", "Rust"]
      },
      "minItems": 0,
      "uniqueItems": true,
      "description": "Workload and context tags for categorization (empty array allowed for bootstrap events)"
    },
    "economic": {
      "type": "object",
      "required": ["cod", "wsjf_score"],
      "properties": {
        "cod": {
          "type": "number",
          "minimum": 0,
          "description": "Cost of Delay (economic impact)"
        },
        "wsjf_score": {
          "type": "number",
          "minimum": 0,
          "description": "Weighted Shortest Job First prioritization score"
        },
        "risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Optional ROAM risk score"
        }
      },
      "additionalProperties": false
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable reason for event emission"
    },
    "action": {
      "type": "string",
      "minLength": 1,
      "description": "Action taken or recommended",
      "examples": [
        "block-and-suggest-fix",
        "suggest",
        "analyze-and-recommend",
        "forensic-analysis",
        "degrade",
        "enforce",
        "track-usage"
      ]
    },
    "prod_mode": {
      "type": "string",
      "enum": ["advisory", "mutate", "enforcement"],
      "description": "Production cycle mode (from AF_PROD_CYCLE_MODE)"
    },
    "metrics": {
      "type": "object",
      "description": "Pattern-specific metrics (schema varies by pattern)",
      "additionalProperties": true
    },
    "context": {
      "type": "object",
      "description": "Optional additional context (deprecated, use metrics)",
      "additionalProperties": true
    },
    "roam_delta": {
      "type": "number",
      "description": "Optional ROAM risk delta for circle participation events"
    },
    "outcome": {
      "type": "string",
      "enum": ["success", "failure", "partial"],
      "description": "Optional outcome for circle participation events"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "ts": "2025-01-30T12:34:56Z",
      "run": "governance-agent",
      "run_id": "gov-1738234567890",
      "iteration": 0,
      "circle": "governance",
      "depth": 0,
      "pattern": "observability-first",
      "pattern:kebab-name": "observability-first",
      "mode": "enforcement",
      "mutation": true,
      "gate": "prod-cycle-gate",
      "framework": "",
      "scheduler": "",
      "tags": ["Federation", "Observability"],
      "economic": {
        "cod": 0.0,
        "wsjf_score": 0.0
      },
      "reason": "observability-first pattern missing in prod-cycle",
      "action": "block-and-suggest-fix",
      "prod_mode": "enforcement",
      "metrics": {
        "enforced": 1,
        "missing_signals": 1,
        "suggestion_made": 1
      }
    },
    {
      "ts": "2025-01-30T12:35:00Z",
      "run": "retro-coach",
      "run_id": "run-1738234567900",
      "iteration": 5,
      "circle": "retro",
      "depth": 0,
      "pattern": "forensic-verification",
      "pattern:kebab-name": "forensic-verification",
      "mode": "advisory",
      "mutation": false,
      "gate": "retro-analysis",
      "framework": "",
      "scheduler": "",
      "tags": ["Federation", "Forensic"],
      "economic": {
        "cod": 0.0,
        "wsjf_score": 0.0
      },
      "reason": "Verified 15/20 actions (75.0%)",
      "action": "forensic-analysis",
      "prod_mode": "advisory",
      "metrics": {
        "verified_count": 15,
        "total_actions": 20,
        "verification_rate_pct": 75.0,
        "avg_cod_delta_pct": -12.5,
        "high_impact_actions": 3,
        "unverified_high_priority": 2
      }
    },
    {
      "ts": "2025-01-30T12:36:00Z",
      "run": "prod-cycle",
      "run_id": "prod-20250130-001",
      "iteration": 3,
      "circle": "analyst",
      "depth": 2,
      "pattern": "ml-training-guardrail",
      "pattern:kebab-name": "ml-training-guardrail",
      "mode": "advisory",
      "mutation": false,
      "gate": "health",
      "framework": "torch",
      "scheduler": "k8s",
      "tags": ["ML", "HPC"],
      "economic": {
        "cod": 5.5,
        "wsjf_score": 7.2
      },
      "reason": "Training checkpoint validation",
      "action": "validate-gradients",
      "prod_mode": "advisory",
      "metrics": {
        "max_epochs": 100,
        "early_stop_triggered": false,
        "grad_explosions": 0,
        "nan_batches": 0,
        "gpu_util_pct": 87.5
      }
    }
  ]
}
