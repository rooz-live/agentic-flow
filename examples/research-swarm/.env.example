# Environment Configuration for Research Swarm Local

# Database Configuration
DATABASE_PATH=

# Output Configuration
OUTPUT_DIR=
REPORT_FORMAT=

# Agent Configuration
DEFAULT_AGENT=
DEFAULT_MAX_RETRIES=
PROGRESS_UPDATE_INTERVAL=

# API Keys (for agentic-flow agents)
# Uncomment and set based on your provider choice

# Anthropic (recommended for highest quality)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenRouter (99% cost savings)
# OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini (free tier available)
# GOOGLE_GEMINI_API_KEY=...

# ONNX (local inference, no API key needed)
# No configuration required for ONNX - runs completely local

# Logging Configuration
LOG_LEVEL="info  # debug, info, warn, error"
VERBOSE_OUTPUT=

# Performance Configuration
EXECUTION_TIMEOUT=
MAX_LOG_SIZE=

# Cleanup Configuration
AUTO_CLEANUP_ENABLED=
CLEANUP_OLDER_THAN_DAYS=
CLEANUP_STATUSES=


# Added keys (2026-01-17)
# Default AWS region
AWS_REGION=us-west-1
# AWS access key (required for S3/EC2)
AWS_ACCESS_KEY_ID="<REQUIRED>"
# AWS secret key
AWS_SECRET_ACCESS_KEY="<REQUIRED>"
# Anthropic Claude API key
ANTHROPIC_API_KEY="<REQUIRED>"
# OpenAI API key
OPENAI_API_KEY="<REQUIRED>"
# Google AI API key
GOOGLE_API_KEY="<REQUIRED>"
# Hivelocity infrastructure API key
HIVELOCITY_API_KEY="<REQUIRED>"
# GitLab host
GITLAB_HOST=gitlab.rooz.live
# GitLab personal access token
GITLAB_TOKEN="<REQUIRED>"
# cPanel host
CPANEL_HOST=cpanel.example.com
# cPanel API token
CPANEL_API_TOKEN="<REQUIRED>"
# cPanel username
CPANEL_USER=your_cpanel_username_here
# PostgreSQL host
POSTGRES_HOST=localhost
# PostgreSQL port
POSTGRES_PORT=5432
# PostgreSQL user
POSTGRES_USER=postgres
# PostgreSQL password
POSTGRES_PASSWORD="<REQUIRED>"
# PostgreSQL database name
POSTGRES_DB=agentic_flow
# Redis host
REDIS_HOST=localhost
# Redis port
REDIS_PORT=6379
# API server port (Grafana uses 3000)
API_PORT=3001
# Frontend port
FRONTEND_PORT=3000
# Node environment (development/staging/production)
NODE_ENV="development  # development, staging, production"
# StarlingX dev host
YOLIFE_STX_HOST=23.92.79.2
# StarlingX SSH port
YOLIFE_STX_PORT=2222
# StarlingX SSH key path
