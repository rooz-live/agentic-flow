# cPanel/WHM Infrastructure Credentials
# Copy to .env.cpanel and fill in values. Sourced by all scripts/infra/* scripts.
# NEVER commit the filled-in .env.cpanel file.

# SSH alias defined in ~/.ssh/config (e.g. rooz-aws)
SSH_ALIAS="rooz-aws"

# Server hostname as seen in WHM
SERVER_HOSTNAME="yo.tag.ooo"

# WHM API token (generate via WHM > Development > API Tokens)
# WHM_API_TOKEN=""

# Domains to monitor (space-separated)
MONITOR_DOMAINS="passbolt.yocloud.com yo.tag.ooo bhopti.com rooz.live"

# SSL warning thresholds (days)
SSL_WARN_DAYS=30
SSL_CRIT_DAYS=7

# Expected CSF TCP_IN ports (comma-separated, compared against server config)
# 853=DNS-over-TLS, 6556=checkmk-agent, 8443=alt-HTTPS
EXPECTED_TCP_IN="20,21,22,25,53,80,110,143,443,465,587,853,993,995,2077,2078,2079,2080,2082,2083,2086,2087,2095,2096,6556,8443"

# DNSSEC-monitored zones (space-separated; zones that SHOULD have valid DNSSEC)
DNSSEC_ZONES="yocloud.com tag.ooo"

# Nginx upstream hosts that must resolve (space-separated)
NGINX_EXPECTED_UPSTREAMS="localhost 127.0.0.1"

