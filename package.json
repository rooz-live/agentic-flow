{
  "name": "agentic-flow",
  "version": "1.0.0",
  "description": "Agentic QE Quality Engineering Pipeline",
  "scripts": {
    "test:unit": "jest",
    "test:e2e-all": "npm run test:e2e:tld && npm run test:trading",
    "test:mutation": "stryker run",
    "coverage": "jest --coverage",
    "start:ocr": "ts-node -O '{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' src/server/ocr-server.ts",
    "lint": "eslint . --quiet",
    "typecheck": "tsc --noEmit",
    "build": "npm run trader:build && mkdir -p dist && cp public/*.html dist/ 2>/dev/null || true",
    "build:validator": "tsc -p scripts/validators/tsconfig.validator.json",
    "trader:dev": "vite --open /compliance --force",
    "trader:build": "vite build",
    "trader:build:tld": "vite build --base=/trading/",
    "trader:preview": "vite preview",
    "test:e2e:tld": "PLAYWRIGHT_TLD_ONLY=1 CONTRACT_BASE_URL=https://analytics.interface.tag.ooo npx playwright test --project=analytics-tld-contract",
    "test:e2e:coach": "PLAYWRIGHT_TLD_ONLY=1 CONTRACT_BASE_URL=https://coach.tag.vote npx playwright test --project=analytics-tld-contract",
    "test:e2e:coach:local": "PLAYWRIGHT_TLD_ONLY=1 CONTRACT_BASE_URL=http://127.0.0.1:5173 npx playwright test --project=analytics-tld-contract",
    "pkill:ports": "bash scripts/kill-dev-ports.sh",
    "test:trading": "npm run pkill:ports && TRADING_URL=/trading.html npx playwright test tests/e2e/trading-dashboard.spec.ts --project=trading-chromium --reporter=list",
    "generate-intake-pdf": "bash /Users/shahroozbhopti/Documents/Personal/CLT/MAA/Uptown/BHOPTI-LEGAL/01-ACTIVE-CRITICAL/MAA-26CV005596-590/validate-legal.sh && npx md-to-pdf /Users/shahroozbhopti/Documents/Personal/CLT/MAA/Uptown/BHOPTI-LEGAL/01-ACTIVE-CRITICAL/MAA-26CV005596-590/DENOVO/ATTORNEY-INTAKE-BRIEF.md --stylesheet tooling/scripts/legal-style.css --pdf-options '{ \"format\": \"Letter\", \"margin\": { \"top\": \"20mm\", \"bottom\": \"20mm\", \"left\": \"20mm\", \"right\": \"20mm\" } }' && mkdir -p .goalie/evidence-bundles && cp /Users/shahroozbhopti/Documents/Personal/CLT/MAA/Uptown/BHOPTI-LEGAL/01-ACTIVE-CRITICAL/MAA-26CV005596-590/DENOVO/ATTORNEY-INTAKE-BRIEF.pdf .goalie/evidence-bundles/hab_life_intake_$(date +%s).pdf"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@stryker-mutator/core": "^8.2.0",
    "@stryker-mutator/instrumenter": "^8.2.0",
    "@stryker-mutator/jest-runner": "^8.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^8.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/cors": "^2.8.19",
