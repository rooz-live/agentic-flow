    "better-sqlite3": "^12.9.0",
    "chokidar": "^3.6.0",
    "cli-spinners": "^3.4.0",
    "cors": "^2.8.6",
    "discord.js": "^14.14.1",
    "express": "^4.22.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.1",
    "md-to-pdf": "^5.2.5",
    "multer": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "reactflow": "^11.11.3",
    "readdirp": "^4.1.2",
    "recharts": "^3.8.1",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0",
