{
  "name": "agentic-flow",
  "version": "2.4.1",
  "description": "Multi-agent coordination framework with QUIC transport",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:full": "./scripts/build-orchestrator.sh --full",
    "build:quick": "./scripts/build-orchestrator.sh --quick",
    "test": "jest",
    "test:security": "./scripts/ci/dependency_check.sh",
    "test:all": "./scripts/build-orchestrator.sh --test-only",
    "test:jest": "jest --passWithNoTests",
    "test:pytest": "python3 -m pytest tests/ -v --tb=short",
    "test:telemetry": "jest --testPathPattern=retro_coach_telemetry --verbose",
    "drift:check": "npx ts-node --transpile-only src/telemetry/offhost-syslog/driftMonitor.ts",
    "validate": "./scripts/build-orchestrator.sh --validate",
    "validate:foundation": "./scripts/validate-foundation.sh",
    "bench:quic": "node benchmarks/quic-transport.bench.js",
    "bench:report": "node scripts/generate-benchmark-report.js",
    "profile": "0x -- node benchmarks/quic-transport.bench.js",
    "lint": "eslint . --ext .ts,.js",
    "typecheck": "tsc --noEmit",
    "dashboard:start": "node scripts/monitoring/dashboard_server.js",
    "dashboard:dev": "node scripts/monitoring/dashboard_server.js --port=3000",
    "federation:start": "./tools/federation/start_federation.sh start",
    "federation:stop": "./tools/federation/start_federation.sh stop",
    "federation:restart": "./tools/federation/start_federation.sh restart",
    "federation:status": "./tools/federation/start_federation.sh status",
    "federation:logs": "./tools/federation/start_federation.sh logs",
    "federation:config": "./tools/federation/start_federation.sh config",
    "governance-agent": "npx ts-node tools/federation/governance_agent.ts",
    "retro-coach": "npx ts-node tools/federation/retro_coach.ts",
    "jujutsu-status": "npx ts-node tools/federation/agentic_jujutsu_integration.ts status",
    "jujutsu-analyze": "npx ts-node tools/federation/agentic_jujutsu_integration.ts analyze",
    "skills:snapshot": "npx ts-node tools/skills/build_skills_snapshot.ts",
    "af:wsjf": "af wsjf",
    "af:prod-cycle": "af prod-cycle",
    "preflight": "./scripts/preflight-check.sh",
    "cache:export": "./scripts/export-skills-cache.sh",
    "cache:export:ts": "npx tsx scripts/export-skills.ts",
    "cache:update": "./scripts/cache-auto-update.sh oneshot",
    "cache:daemon": "./scripts/cache-auto-update.sh daemon",
    "cache:status": "./scripts/cache-auto-update.sh status",
    "mcp:health": "./scripts/mcp-health-check.sh",
    "mcp:start": "./scripts/mcp-start.sh",
    "mcp:setup": "./scripts/mcp-setup.sh",
    "mcp:diagnose": "./scripts/mcp-setup.sh diagnose",
    "mcp:fix": "./scripts/mcp-setup.sh fix"
  },
  "keywords": [
    "quic",
    "multi-agent",
    "performance",
    "benchmark"
  ],
  "author": "Performance Benchmarker Agent",
  "license": "MIT",
  "dependencies": {
    "@cosmograph/cosmograph": "^2.0.1",
    "@cosmograph/react": "^2.0.1",
    "@cosmos.gl/graph": "^2.6.2",
    "@deck.gl/geo-layers": "^9.2.5",
    "@deck.gl/react": "^9.2.5",
    "@discordjs/rest": "^0.4.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fails-components/webtransport": "^1.5.1",
    "@huggingface/inference": "^4.13.5",
    "@mui/lab": "^7.0.1-beta.20",
    "@mui/material": "^7.3.6",
    "@opentelemetry/auto-instrumentations-node": "^0.67.3",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@ruvector/core": "^0.1.29",
    "@ruvector/graph-node": "^0.1.25",
    "@ruvector/ruvllm": "^0.2.3",
    "@traceloop/node-server-sdk": "^0.22.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "agentdb": "^1.6.1",
    "autoprefixer": "^10.4.23",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "claude-flow": "^2.7.47",
    "claude-presentation-master": "^3.6.0",
    "deck.gl": "^9.2.5",
    "discord-api-types": "^0.38.37",
    "discord-interactions": "^4.4.0",
    "discord.js": "^13.17.1",
    "dspy.ts": "^2.1.1",
    "goalie": "^1.3.1",
    "lucide-react": "^0.562.0",
    "neo4j-driver": "^6.0.1",
    "node-cron": "^4.2.1",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-map-gl": "^8.1.0",
    "react-router-dom": "^7.11.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.6.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.0.2",
    "stripe": "^20.1.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^7.3.0",
    "ws": "^8.18.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@deck.gl/core": "^9.2.5",
    "@deck.gl/layers": "^9.2.5",
    "@mui/icons-material": "^7.3.6",
    "@ruvector/agentic-synth": "^0.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^4.0.0",
    "@types/inquirer": "^9.0.9",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3",
    "@types/react-map-gl": "^6.1.7",
    "@types/testing-library__react": "^10.0.1",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "0x": "^6.0.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "jsdom": "^27.4.0",
    "tar": "^7.5.7",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "xml2js": "^0.6.2"
  },
  "overrides": {
    "d3-color": "^3.1.0",
    "qs": "^6.14.1",
    "jws": "^4.0.1",
    "glob": "^10.5.0",
    "body-parser": "^2.2.1",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "tar": "^7.5.7",
    "xml2js": "^0.6.2",
    "elliptic": "^6.6.1",
    "fast-xml-parser": "^5.3.4"
  },
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rooz-live/agentic-flow.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/rooz-live/agentic-flow/issues"
  },
  "homepage": "https://github.com/rooz-live/agentic-flow#readme"
}
