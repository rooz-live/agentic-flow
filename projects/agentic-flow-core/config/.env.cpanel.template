#!/usr/bin/env bash
# cPanel / WHM / related service credentials
# Copy to config/.env.cpanel OR credentials/.env.cpanel (both are sourced by scripts/infra).
# Optional: export CREDENTIALS_ENV_FILE=/path/to/secret.env before running scripts.
#
# API tokens: cPanel → Security → Manage API Tokens | WHM → Development → Manage API Tokens

# ── Default host (yo.tag.ooo server) ─────────────────────────────────────────
export CPANEL_HOST="yo.tag.ooo"
export CPANEL_DOMAIN="yo.tag.ooo"

# ── Per-domain cPanel tokens ─────────────────────────────────────────────────
export CPANEL_USER_TAG="tag"
export CPANEL_TOKEN_TAG=""

export CPANEL_USER_BHOPTI="bhopti"
export CPANEL_TOKEN_BHOPTI=""

export CPANEL_USER_ROOZ="rooz"
export CPANEL_TOKEN_ROOZ=""

export CPANEL_USER_YO="yo"
export CPANEL_TOKEN_YO=""

export CPANEL_USER_YOSERVICE="yoservice"
export CPANEL_TOKEN_YOSERVICE=""

# ── WHM (whmapi1 / JSON-API) ────────────────────────────────────────────────
export WHM_HOST="yo.tag.ooo"
export WHM_USER="root"
export WHM_TOKEN=""

# ── SSH (CSF / deploy scripts) ───────────────────────────────────────────────
export CPANEL_SSH_HOST="rooz-aws"

# ── SSL monitoring ───────────────────────────────────────────────────────────
export SSL_CHECK_INTERVAL="3600"
export SSL_ALERT_EMAIL=""
export SSL_RENEWAL_THRESHOLD_DAYS="30"
export SSL_AUTO_TRIGGER="false"

# ── HostBill (API) ────────────────────────────────────────────────────────────
export HOSTBILL_URL="https://billing.example.com"
export HOSTBILL_API_ID=""
export HOSTBILL_API_KEY=""

# ── GitLab ───────────────────────────────────────────────────────────────────
export GITLAB_URL="https://gitlab.example.com"
export GITLAB_TOKEN=""

# ── OpenStack / STX CLI ───────────────────────────────────────────────────────
export OS_AUTH_URL=""
export OS_USERNAME=""
export OS_PASSWORD=""
export OS_PROJECT_NAME=""
export OS_USER_DOMAIN_NAME="Default"
export OS_PROJECT_DOMAIN_NAME="Default"

# ── Passbolt CLI / Playwright automation ─────────────────────────────────────
export PASSBOLT_SERVER="https://passbolt.example.com"
export PASSBOLT_USER_PRIVATE_KEY_FILE=""

# ── StarlingX / YOLIFE SSH (scripts/infra/stx) ───────────────────────────────
export YOLIFE_STX_HOST=""
export YOLIFE_STX_USER="ubuntu"
export YOLIFE_STX_KEY=""
export YOLIFE_STX_PORTS="2222"

# ── WHM firewall write gate (optional) ────────────────────────────────────────
# export WHM_FIREWALL_CONFIRM=1   # DANGER: allows restart without --confirm
# export WHM_AUDIT_LOG="$HOME/.goalie/whm-audit.jsonl"
