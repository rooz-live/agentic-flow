#!/usr/bin/env bash
# cPanel Persistent Credentials
# Copy to .env.cpanel and fill in real values. Sourced by scripts/infra/cpanel/*.sh
#
# To create API tokens:
#   cPanel → Security → Manage API Tokens → Create
#   WHM    → Development → Manage API Tokens → Generate

# ── Default host (yo.tag.ooo server) ─────────────────────────────────────────
export CPANEL_HOST="yo.tag.ooo"
export CPANEL_DOMAIN="yo.tag.ooo"

# ── Per-domain tokens ────────────────────────────────────────────────────────
export CPANEL_USER_TAG="tag"
export CPANEL_TOKEN_TAG=""           # tag@yo.tag.ooo

export CPANEL_USER_BHOPTI="bhopti"
export CPANEL_TOKEN_BHOPTI=""        # bhopti@bhopti.com

export CPANEL_USER_ROOZ="rooz"
export CPANEL_TOKEN_ROOZ=""          # rooz@rooz.live

export CPANEL_USER_YO="yo"
export CPANEL_TOKEN_YO=""            # yo@yo.life

export CPANEL_USER_YOSERVICE="yoservice"
export CPANEL_TOKEN_YOSERVICE=""     # yoservice@yoservice.com

# ── WHM root token (for whmapi1 calls) ───────────────────────────────────────
export WHM_HOST="yo.tag.ooo"
export WHM_USER="root"
export WHM_TOKEN=""

# ── SSH shortcut (for firewall/remote scripts) ───────────────────────────────
export CPANEL_SSH_HOST="rooz-aws"    # matches ~/.ssh/config Host entry

# ── SSL monitoring ───────────────────────────────────────────────────────────
export SSL_CHECK_INTERVAL="3600"
export SSL_ALERT_EMAIL=""
export SSL_RENEWAL_THRESHOLD_DAYS="30"
export SSL_AUTO_TRIGGER="false"
