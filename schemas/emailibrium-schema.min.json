{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Emailibrium Classification Signal",
  "description": "Standardized JSON schema for n8n/emailibrium out-of-repo webhooks to inject ROAM tensions into the Swarm WSJF ledger.",
  "type": "object",
  "required": [
    "signal_id",
    "source",
    "timestamp",
    "confidence_score",
    "classification",
    "roam_risk_mapping"
  ],
  "properties": {
    "signal_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the incoming triage signal."
    },
    "source": {
      "type": "string",
      "enum": [
        "n8n-email",
        "finelo-alert",
        "zero-day-cve",
        "server-log"
      ],
      "description": "Origin of the signal."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp of the original event."
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "ML classifier confidence score (0.0 to 1.0)."
    },
    "classification": {
      "type": "string",
      "enum": [
        "URGENT_ACTION_REQUIRED",
        "TENSION_DISCOVERED",
        "PASSIVE_LOG",
        "SPAM_REJECT"
      ],
      "description": "Categorical routing intent determined by the out-of-repo mesh."
    },
    "roam_risk_mapping": {
      "type": "object",
      "required": ["impact", "category"],
      "properties": {
        "impact": {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
        },
        "category": {
          "type": "string",
          "enum": [
            "Cognitive Drift",
            "Financial/Tax",
            "Infrastructure Bleed",
            "Security Vulnerability",
            "Other"
          ]
        },
        "suggested_wsjf_penalty": {
          "type": "number",
          "description": "Proposed modifier to deduct/add to the next PI cycle WSJF score."
        }
      }
    },
    "raw_context": {
      "type": "string",
      "description": "The unstructured body text, sanitized for DB ingestion."
    }
  },
  "additionalProperties": false
}
