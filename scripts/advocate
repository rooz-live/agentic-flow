#!/bin/bash
# advocate: CLI wrapper for wholeness validation and governance council

set -e

# Base directory for agentic-flow tools
FLOW_DIR="/Users/shahroozbhopti/Documents/code/investing/agentic-flow"
LEGAL_DIR="/Users/shahroozbhopti/Documents/Personal/CLT/MAA/Uptown/BHOPTI-LEGAL/11-ADVOCACY-PIPELINE"

function show_help() {
    echo "Usage: advocate <command> [options]"
    echo ""
    echo "Commands:"
    echo "  validate <file> [options]   Run wholeness validator (Circles, Roles, Patterns)"
    echo "  council                     Run governance council voting (Interactive/Python API)"
    echo "  help                        Show this help"
    echo ""
    echo "Validation Options:"
    echo "  --circles <list>            Specific circles (default: all)"
    echo "  --roles <list>              Specific roles (default: all)"
    echo "  --patterns <list>           Software patterns (prd,adr,ddd,tdd)"
    echo ""
    echo "Examples:"
    echo "  advocate validate document.md"
    echo "  advocate validate lease.txt --patterns prd,adr"
}

case "$1" in
    validate|v)
        shift
        python3 -m vibesthinker.advocate_cli validate "$@"
        ;;
    cycle|cy)
        shift
        python3 -m vibesthinker.advocate_cli cycle "$@"
        ;;
    council|c)
        shift
        python3 "$LEGAL_DIR/vibesthinker/governance_council.py" "$@"
        ;;
    dashboard|d)
        shift
        python3 -m vibesthinker.advocate_cli dashboard "$@"
        ;;
    help|--help|-h)
        python3 -m vibesthinker.advocate_cli --help
        ;;
    *)
        # Default to passing through to CLI
        python3 -m vibesthinker.advocate_cli "$@"
        ;;
esac
