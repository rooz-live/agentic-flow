{
  "cycle_phase_chunking": {
    "iteration_phase": {
      "strategy": "auto",
      "max_chunk_size": 4096,
      "overlap_tokens": 256,
      "enforce_strict_bounds": true,
      "limits": {
        "assessor_circle": 0.20,
        "intuitive_circle": 0.20,
        "orchestrator_circle": 0.15,
        "innovator_circle": 0.15,
        "analyst_circle": 0.15,
        "seeker_circle": 0.15
      }
    },
    "gate_phase": {
      "strategy": "static",
      "max_chunk_size": 8192,
      "overlap_tokens": 128,
      "validation_threshold": 1000
    },
    "increment_phase": {
      "strategy": "multi",
      "max_chunk_size": 2048,
      "overlap_tokens": 512,
      "fallback_mode": "truncate"
    }
  },
  "hyperbolic_ui_tuning": {
    "fps_throttle_ui": 30,
    "canvas_vertex_limit": 5000,
    "vector_batch_size": 250
  }
}
