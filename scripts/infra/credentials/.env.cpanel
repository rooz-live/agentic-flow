# cPanel/WHM Persistent Credentials
# Source this file in cpanel/ and whm/ scripts:
#   source "$(dirname "$0")/../credentials/.env.cpanel"
#
# NEVER commit real values — this file is in .gitignore.
# Copy to .env.cpanel.local with real values.

# ── Default host ──────────────────────────────────────────────────────────────
export CPANEL_HOST="${CPANEL_HOST:-yo.tag.ooo}"
export CPANEL_USER="${CPANEL_USER:-tag}"
export CPANEL_API_TOKEN="${CPANEL_API_TOKEN:-}"

# ── Per-domain tokens (override CPANEL_API_TOKEN per site) ────────────────────
export CPANEL_TOKEN_TAG="${CPANEL_TOKEN_TAG:-$CPANEL_API_TOKEN}"
export CPANEL_TOKEN_BHOPTI="${CPANEL_TOKEN_BHOPTI:-}"
export CPANEL_TOKEN_ROOZ="${CPANEL_TOKEN_ROOZ:-}"
export CPANEL_TOKEN_YO="${CPANEL_TOKEN_YO:-}"
export CPANEL_TOKEN_YOSERVICE="${CPANEL_TOKEN_YOSERVICE:-}"

# ── WHM root access ───────────────────────────────────────────────────────────
export WHM_HOST="${WHM_HOST:-$CPANEL_HOST}"
export WHM_USER="${WHM_USER:-root}"
export WHM_API_TOKEN="${WHM_API_TOKEN:-}"

# ── SSH access (for firewall/remote scripts) ──────────────────────────────────
export CPANEL_SSH_HOST="${CPANEL_SSH_HOST:-rooz-aws}"  # matches ~/.ssh/config
export CPANEL_SSH_KEY="${CPANEL_SSH_KEY:-~/pem/rooz.pem}"
export CPANEL_SSH_PORT="${CPANEL_SSH_PORT:-22}"

# ── SSL monitoring ────────────────────────────────────────────────────────────
export SSL_CHECK_INTERVAL="${SSL_CHECK_INTERVAL:-3600}"
export SSL_ALERT_EMAIL="${SSL_ALERT_EMAIL:-}"
export SSL_RENEWAL_THRESHOLD_DAYS="${SSL_RENEWAL_THRESHOLD_DAYS:-30}"
