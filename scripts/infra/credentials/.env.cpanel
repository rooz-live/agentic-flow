# cPanel/WHM Persistent Credentials
# Source this file in cpanel/ and whm/ scripts:
#   source "$(dirname "$0")/../credentials/.env.cpanel"
#
# NEVER commit real values — this file is in .gitignore.
# Copy to .env.cpanel.local with real values.

export CPANEL_HOST="${CPANEL_HOST:-cpanel.rooz.live}"
export CPANEL_USER="${CPANEL_USER:-rooz}"
export CPANEL_API_TOKEN="${CPANEL_API_TOKEN:-}"

export WHM_HOST="${WHM_HOST:-$CPANEL_HOST}"
export WHM_USER="${WHM_USER:-root}"
export WHM_API_TOKEN="${WHM_API_TOKEN:-}"

# SSH access (for direct server ops)
export CPANEL_SSH_KEY="${CPANEL_SSH_KEY:-~/pem/rooz.pem}"
export CPANEL_SSH_PORT="${CPANEL_SSH_PORT:-22}"
