# .env.cpanel — Canonical credential file for all infra scripts
# Copy to .env.cpanel (gitignored), fill in real values.
# Source: source scripts/infra/credentials/.env.cpanel
# Auto-registered by: cpanel-env-setup.sh --persist
#
# This file is the single source of truth consumed by:
#   - bash scripts (cpanel-dns-zone.sh, cpanel-ssl-monitor.sh, whm-firewall-check.sh)
#   - Ansible (inventory/group_vars/all.yml reads these via lookup('env', ...))
#   - Python (hostbill_api_client.py, cpanel_ssh_client.py, stx-deploy.sh)
#   - launchd (com.agentic-flow.ssl-monitor.plist sources this file)

# ── cPanel / WHM ──────────────────────────────────────────────────────────────
export CPANEL_HOST="yo.tag.ooo"
export CPANEL_USER="tag"
export CPANEL_API_TOKEN=""          # cPanel UAPI token (not root password)
export WHM_API_TOKEN=""             # WHM whmapi1 token (separate from cPanel token)
export CPANEL_SSH_KEY="$HOME/pem/rooz.pem"

# ── HostBill ──────────────────────────────────────────────────────────────────
export HOSTBILL_URL="https://hostbillapp.com"
export HOSTBILL_API_KEY=""          # HostBill admin API key
export HOSTBILL_API_ID=""           # HostBill API user ID (integer)

# ── STX / OpenStack ───────────────────────────────────────────────────────────
export STX_HOST="stx-aio-0.corp.interface.tag.ooo"
export STX_SSH_KEY="$HOME/.ssh/starlingx_key"
export STX_SSH_PORT="2222"
export OS_AUTH_URL=""               # e.g. http://STX_HOST:5000/v3
export OS_PROJECT_NAME="admin"
export OS_USERNAME="admin"
export OS_PASSWORD=""
export OS_REGION_NAME="RegionOne"
export OS_PROJECT_DOMAIN_NAME="Default"
export OS_USER_DOMAIN_NAME="Default"
export OS_IDENTITY_API_VERSION="3"

# ── GitLab / GitHub ───────────────────────────────────────────────────────────
export GITLAB_API_TOKEN=""
export GITHUB_TOKEN=""

# ── Passbolt ──────────────────────────────────────────────────────────────────
export PASSBOLT_SERVER="https://passbolt.yocloud.com"
export PASSBOLT_KEY_FILE="$HOME/pem/passbolt-key.asc"
