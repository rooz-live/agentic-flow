# Dockerfile.le-wm
# Containerized environment for compiling and running the le-wm Wayland compositor.
# Useful if running natively on macOS via Waypipe or a local X11/VNC server.

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Install Rust and Wayland dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    build-essential \
    pkg-config \
    libwayland-dev \
    libxkbcommon-dev \
    libegl1-mesa-dev \
    libgles2-mesa-dev \
    libgbm-dev \
    libinput-dev \
    libudev-dev \
    libseat-dev \
    libpixman-1-dev \
    libxcb1-dev \
    libxcb-composite0-dev \
    libxcb-render0-dev \
    libxcb-shape0-dev \
    libxcb-xfixes0-dev \
    xwayland \
    waypipe \
    && rm -rf /var/lib/apt/lists/*

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Clone le-wm
WORKDIR /opt/le-wm
RUN git clone https://github.com/lucas-maes/le-wm.git .

# Compile le-wm
RUN cargo build --release

# Entrypoint setup
# Waypipe allows forwarding the Wayland socket over SSH/TCP back to a macOS Wayland client if needed.
CMD ["/opt/le-wm/target/release/le-wm"]
