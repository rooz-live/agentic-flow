{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StarlingX Hardware Telemetry Bounds",
  "description": "Validation Schema ensuring physical IPMI arrays resolve strictly before mapping HostBill limits.",
  "type": "object",
  "properties": {
    "node_id": {
      "type": "string",
      "pattern": "^stx-aio-[0-9]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "ipmi_telemetry": {
      "type": "object",
      "properties": {
        "pmbus_watts": {
          "type": "number",
          "minimum": 0,
          "maximum": 5000,
          "description": "Physical watt output protecting arrays preventing 0-byte arrays mapping upstream."
        },
        "power_overload_flag": {
          "type": "boolean"
        },
        "cpu_thermal_celsius": {
          "type": "number",
          "minimum": -10,
          "maximum": 110
        }
      },
      "required": ["pmbus_watts", "power_overload_flag", "cpu_thermal_celsius"],
      "additionalProperties": false
    },
    "hostbill_mapping_usd": {
      "type": "number",
      "minimum": 0,
      "description": "Dynamically calculated PMBus baseline translation."
    },
    "tier_classification": {
      "type": "string",
      "enum": ["ENTERPRISE_TIER_1", "ENTERPRISE_TIER_2", "STANDARD"]
    }
  },
  "required": ["node_id", "timestamp", "ipmi_telemetry", "hostbill_mapping_usd", "tier_classification"],
  "additionalProperties": false
}
