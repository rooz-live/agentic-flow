{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Canonical Gate Policy (MPP)",
  "description": "One canonical home per concern; shims expire in one release cycle.",
  "canonical_owners": {
    "orchestration": "scripts/one.sh",
    "gate_dispatch": "scripts/gate-one-pass.sh",
    "trust_foundation": "scripts/validate-foundation.sh",
    "dedupe_audit": "scripts/ci/check-gate-dedupe.sh",
    "continuous_learning": "scripts/cicd/continuous_learning_swarm.sh",
    "cls_config": "config/cicd/continuous_learning.yaml",
    "dod_gate": "code/tooling/scripts/dod-gate.sh",
    "session_dor": "code/tooling/scripts/agent_session_dor.sh",
    "evidence_lib": "code/tooling/scripts/lib/evidence_json.sh",
    "edge_smoke": "tooling/scripts/cog_edge_smoke.sh",
    "public_synthetic": "code/tooling/scripts/public_synthetic_check.sh",
    "compliance_cog": "scripts/governance/compliance_as_code.py",
    "roam_watchdog": "scripts/roam-staleness-watchdog.sh",
    "wsjf": "scripts/wsjf/upgrade_wave4_workflow.py",
    "evidence_root": ".goalie/evidence/",
    "upstream_queue": ".goalie/UPSTREAM_ACTIONS.yaml"
  },
  "shims_only": [
    "scripts/agent_session_dor.sh",
    "scripts/public_synthetic_check.sh",
    "scripts/dod-gate.sh",
    "scripts/gate-one-pass.sh"
  ],
  "legacy_dedupe_guard": [
    "scripts/one.sh",
    "scripts/ci/check-gate-dedupe.sh",
    "scripts/generate_native_app.sh",
    "scripts/compile_native_artifacts.sh",
    "scripts/provision_cpanel_repo.sh"
