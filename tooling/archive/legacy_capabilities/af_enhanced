# --- Production Status Management ---
initialize_prod_status() {
    local status_file="$1"
    local run_id="$2"
    local command="$3"
    
    if [ ! -f "$status_file" ]; then
        cat > "$status_file" << EOF
{
  "run_id": "$run_id",
  "command": "$command",
  "start_time": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "status": "initializing",
  "multipass": $MULTIPASS,
  "preflight_iters": $PREFLIGHT_ITERS,
  "progress_tooltip": "$PROGRESS_TOOLTIP",
  "environment": "$AF_ENV",
  "mode": "$MODE",
  "circle": "$CIRCLE",
  "testing": "$TESTING",
  "steps": [],
  "metrics": {},
  "health_checks": {},
  "validation_results": {},
  "evidence_trails": []
}
EOF
    fi
}

update_prod_status() {
    local status_file="$1"
    local step="$2"
    local status="$3"
    local message="$4"
    local metrics="$5"
    
    if [ -f "$status_file" ]; then
        # Use Python to update JSON safely
        python3 -c "
import json
import sys
import datetime

status_file = '$status_file'
step = '$step'
new_status = '$status'
message = '$message'
metrics = '$metrics'

try:
    with open(status_file, 'r') as f:
        data = json.load(f)
    
    # Update step
    step_entry = {
        'step': step,
        'status': new_status,
        'message': message,
        'timestamp': datetime.datetime.utcnow().isoformat() + 'Z'
    }
    
    # Find existing step or add new one
    existing_step = None
    for i, s in enumerate(data.get('steps', [])):
        if s.get('step') == step:
            existing_step = i
            break
    
    if existing_step is not None:
        data['steps'][existing_step] = step_entry
    else:
        data.setdefault('steps', []).append(step_entry)
    
    # Update overall status
    data['status'] = new_status
    data['last_update'] = datetime.datetime.utcnow().isoformat() + 'Z'
    
    # Add metrics if provided
    if metrics:
        import ast
        try:
            metrics_dict = ast.literal_eval(metrics)
            data['metrics'].update(metrics_dict)
        except:
            pass
    
    # Write back to file
    with open(status_file, 'w') as f:
        json.dump(data, f, indent=2)
    
    print(f'Updated production status: {step} -> {new_status}')
except Exception as e:
    print(f'Error updating production status: {e}', file=sys.stderr)
    sys.exit(1)
"
    fi
}

show_progress_tooltip() {
    local mode="$1"
    local step="$2"
    local status="$3"
    local message="$4"
    
    case $mode in
        compact)
            echo "[$(date '+%H:%M:%S')] $step: $status - $message"
            ;;
        rich)
            echo "🔄 [$(date '+%H:%M:%S')] $step: $status"
            echo "   📝 $message"
            ;;
        json)
            echo "{\"timestamp\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\", \"step\": \"$step\", \"status\": \"$status\", \"message\": \"$message\"}"
            ;;
        write-status-file)
            if [ -n "$PROGRESS_STATUS_FILE" ]; then
                echo "{\"timestamp\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\", \"step\": \"$step\", \"status\": \"$status\", \"message\": \"$message\"}" >> "$PROGRESS_STATUS_FILE"
            fi
            ;;
        off|*)
            # No output
            ;;
    esac
}

# --- Multipass Pre/Post Cycle Integration ---
run_multipass_preflight() {
    local command="$1"
    local preflight_iters="$2"
    
    echo "🚀 Running multipass preflight with $preflight_iters iterations..."
    
    # Initialize production status
    initialize_prod_status "$PROD_STATUS_FILE" "$AF_RUN_ID" "$command"
    update_prod_status "$PROD_STATUS_FILE" "multipass_preflight" "running" "Starting multipass preflight" "{\"preflight_iters\": $preflight_iters}"
    
    # Run preflight iterations
    for ((i=1; i<=preflight_iters; i++)); do
        show_progress_tooltip "$PROGRESS_TOOLTIP" "preflight_iteration_$i" "running" "Running preflight iteration $i of $preflight_iters"
        
        # Run command with reduced iterations
        if [ "$command" = "prod-cycle" ]; then
            run_prod_cycle_preflight "$i" "$preflight_iters"
        elif [ "$command" = "prod-swarm" ]; then
            run_prod_swarm_preflight "$i" "$preflight_iters"
        fi
        
        # Check for early regression detection
        if check_for_regressions "$i" "$preflight_iters"; then
            update_prod_status "$PROD_STATUS_FILE" "multipass_preflight" "failed" "Regression detected at iteration $i" "{\"failed_iteration\": $i}"
            echo "❌ Regression detected at iteration $i, stopping preflight"
            return 1
        fi
    done
    
    update_prod_status "$PROD_STATUS_FILE" "multipass_preflight" "completed" "Multipass preflight completed successfully" "{\"total_iterations\": $preflight_iters}"
    echo "✅ Multipass preflight completed successfully"
    return 0
}

check_for_regressions() {
    local current_iter="$1"
    local total_iters="$2"
    
    # Check for performance regressions in pattern metrics
    if [ -f "$PROJECT_ROOT/.goalie/pattern_metrics.jsonl" ]; then
        local recent_metrics=$(tail -n 5 "$PROJECT_ROOT/.goalie/pattern_metrics.jsonl" | python3 -c "
import json
import sys

metrics = []
for line in sys.stdin:
    try:
        metrics.append(json.loads(line))
    except:
        pass

if len(metrics) >= 2:
    latest = metrics[-1].get('performance_score', 0)
    previous = metrics[-2].get('performance_score', 0)
    if latest < previous * 0.9:  # 10% regression threshold
        print('REGRESSION_DETECTED')
        sys.exit(0)

print('NO_REGRESSION')
")
        
        if [ "$recent_metrics" = "REGRESSION_DETECTED" ]; then
            return 0  # Regression detected
        fi
    fi
    
    return 1  # No regression
}

run_prod_cycle_preflight() {
    local iteration="$1"
    local total_iters="$2"
    
    # Build preflight command with reduced iterations
    local preflight_args=(
        "--mode" "$MODE"
        "--iterations" "5"  # Fixed small iterations for preflight
        "--testing" "$TESTING"
    )
    
    [ -n "$CIRCLE" ] && preflight_args+=("--circle" "$CIRCLE")
    [ "$JSON_OUTPUT" = true ] && preflight_args+=("--json")
    [ "$VERBOSE" = true ] && preflight_args+=("--verbose")
    
    if [ -f "$SCRIPT_DIR/af/af_prod_cycle.py" ]; then
        python3 "$SCRIPT_DIR/af/af_prod_cycle.py" "${preflight_args[@]}" > /dev/null 2>&1 || true
    fi
}

run_prod_swarm_preflight() {
    local iteration="$1"
    local total_iters="$2"
    
    # Build preflight command with reduced iterations
    local preflight_args=(
        "--generate-mock"
        "--mock-output-dir" "preflight_$iteration"
        "--json"
    )
    
    [ "$VERBOSE" = true ] && preflight_args+=("--verbose")
    
    if [ -f "$SCRIPT_DIR/af/af_prod_swarm.py" ]; then
        python3 "$SCRIPT_DIR/af/af_prod_swarm.py" "${preflight_args[@]}" > /dev/null 2>&1 || true
    fi
}

# --- Command Execution Functions ---
execute_prod_cycle() {
    echo "🔄 Running production cycle with multipass integration..."
    
    # Initialize production status
    initialize_prod_status "$PROD_STATUS_FILE" "$AF_RUN_ID" "prod-cycle"
    update_prod_status "$PROD_STATUS_FILE" "prod_cycle" "initializing" "Starting production cycle" "{\"mode\": \"$MODE\", \"circle\": \"$CIRCLE\"}"
    
    # Run multipass preflight if enabled
    if [ "$MULTIPASS" = true ]; then
        if ! run_multipass_preflight "prod-cycle" "$PREFLIGHT_ITERS"; then
            echo "❌ Multipass preflight failed, aborting production cycle"
            update_prod_status "$PROD_STATUS_FILE" "prod_cycle" "failed" "Multipass preflight failed"
            return 1
        fi
    fi
    
    show_progress_tooltip "$PROGRESS_TOOLTIP" "prod_cycle" "running" "Executing production cycle"
    update_prod_status "$PROD_STATUS_FILE" "prod_cycle" "running" "Executing production cycle"
    
    # Build command arguments
    local args=(
        "--mode" "$MODE"
        "--json"  # Always use JSON for internal communication
    )
    
    # Add optional arguments
    [ -n "$CIRCLE" ] && args+=("--circle" "$CIRCLE")
    [ "$TESTING" != "none" ] && args+=("--testing" "$TESTING")
    [ "$VERBOSE" = true ] && args+=("--verbose")
    [ "$DRY_RUN" = true ] && args+=("--dry-run")
    [ "$LOG_GOALIE" = true ] && args+=("--log-goalie")
    [ "$SAFEGUARDS" = true ] && args+=("--safeguards")
    [ "$ROLLOUT_STRATEGY" != "gradual" ] && args+=("--rollout-strategy" "$ROLLOUT_STRATEGY")
    [ "$VALIDATION" = true ] && args+=("--validation")
    [ "$PATTERN_METRICS" = true ] && args+=("--pattern-metrics")
    [ "$COMPLIANCE_CHECKS" = true ] && args+=("--compliance-checks")
    [ "$TIER_DEPTH_COVERAGE" = false ] && args+=("--no-tier-depth-coverage")
    [ -n "$ITERATIONS" ] && args+=("--iterations" "$ITERATIONS")
    [ "$NO_EARLY_STOP" = true ] && args+=("--no-early-stop")
    
    # Execute production cycle
    if [ "$DRY_RUN" = true ]; then
        echo "DRY RUN: Would execute: python3 $SCRIPT_DIR/af/af_prod_cycle.py ${args[*]}"
        return 0
    fi
    
    if [ -f "$SCRIPT_DIR/af/af_prod_cycle.py" ]; then
        python3 "$SCRIPT_DIR/af/af_prod_cycle.py" "${args[@]}"
        local exit_code=$?
    else
        echo "Error: Production cycle script not found"
        update_prod_status "$PROD_STATUS_FILE" "prod_cycle" "failed" "Production cycle script not found"
        return 1
    fi
    
    # Handle tier depth coverage if enabled
    if [ "$TIER_DEPTH_COVERAGE" = true ] && [ "$exit_code" -eq 0 ]; then
        show_progress_tooltip "$PROGRESS_TOOLTIP" "tier_depth_coverage" "running" "Running tier depth coverage analysis"
        update_prod_status "$PROD_STATUS_FILE" "tier_depth_coverage" "running" "Running tier depth coverage analysis"
        
        local td_args=("--correlation-id" "$AF_RUN_ID")
        [ -n "$CIRCLE" ] && td_args+=("--circle" "$CIRCLE")
        [ "$CIRCLE" = "testing" ] && td_args+=("--tier1-circles" "orchestrator,assessor,testing")
        [ "$JSON_OUTPUT" = true ] && td_args+=("--json")
        
        if [ -f "$SCRIPT_DIR/../investing/agentic-flow/scripts/cmd_tier_depth_coverage.py" ]; then
            python3 "$SCRIPT_DIR/../investing/agentic-flow/scripts/cmd_tier_depth_coverage.py" "${td_args[@]}"
        else
            echo "Warning: Tier depth coverage script not found, skipping"
        fi
        
        update_prod_status "$PROD_STATUS_FILE" "tier_depth_coverage" "completed" "Tier depth coverage analysis completed"
    fi
    
    # Update final status
    if [ "$exit_code" -eq 0 ]; then
        update_prod_status "$PROD_STATUS_FILE" "prod_cycle" "completed" "Production cycle completed successfully"
        show_progress_tooltip "$PROGRESS_TOOLTIP" "prod_cycle" "completed" "Production cycle completed successfully"
    else
        update_prod_status "$PROD_STATUS_FILE" "prod_cycle" "failed" "Production cycle failed with exit code $exit_code"
        show_progress_tooltip "$PROGRESS_TOOLTIP" "prod_cycle" "failed" "Production cycle failed with exit code $exit_code"
    fi
    
    return $exit_code
}

execute_prod_swarm() {
    echo "🔄 Running production swarm with multipass integration..."
    
    # Initialize production status
    initialize_prod_status "$PROD_STATUS_FILE" "$AF_RUN_ID" "prod-swarm"
    update_prod_status "$PROD_STATUS_FILE" "prod_swarm" "initializing" "Starting production swarm"
    
    # Run multipass preflight if enabled
    if [ "$MULTIPASS" = true ]; then
        if ! run_multipass_preflight "prod-swarm" "$PREFLIGHT_ITERS"; then
            echo "❌ Multipass preflight failed, aborting production swarm"
            update_prod_status "$PROD_STATUS_FILE" "prod_swarm" "failed" "Multipass preflight failed"
            return 1
        fi
    fi
    
    show_progress_tooltip "$PROGRESS_TOOLTIP" "prod_swarm" "running" "Executing production swarm"
    update_prod_status "$PROD_STATUS_FILE" "prod_swarm" "running" "Executing production swarm"
    
    # Build command arguments
    local args=(
        "--json"  # Always use JSON for internal communication
    )
    
    # Add optional arguments
    [ -n "$PRIOR" ] && args+=("--prior" "$PRIOR")
    [ -n "$CURRENT" ] && args+=("--current" "$CURRENT")
    [ -n "$AUTO_REF" ] && args+=("--auto-ref" "$AUTO_REF")
    [ "$OUT_FORMAT" != "json" ] && args+=("--out" "$OUT_FORMAT")
    [ -n "$SAVE" ] && args+=("--save" "$SAVE")
    [ "$VERBOSE" = true ] && args+=("--verbose")
    [ "$LOG_GOALIE" = true ] && args+=("--log-goalie")
    [ "$GENERATE_MOCK" = true ] && args+=("--generate-mock")
    [ "$MOCK_OUTPUT_DIR" != "swarm_data" ] && args+=("--mock-output-dir" "$MOCK_OUTPUT_DIR")
    [ "$DISCOVER" = true ] && args+=("--discover")
    [ "$SAVE_TABLE" = true ] && args+=("--save-table")
    [ "$TABLE_LABEL" != "current" ] && args+=("--table-label" "$TABLE_LABEL")
    [ "$AUTO_COMPARE" = true ] && args+=("--auto-compare")
    [ "$VALIDATE_ONLY" = true ] && args+=("--validate-only")
    
    # Execute production swarm
    if [ "$DRY_RUN" = true ]; then
        echo "DRY RUN: Would execute: python3 $SCRIPT_DIR/af/af_prod_swarm.py ${args[*]}"
        return 0
    fi
    
    if [ -f "$SCRIPT_DIR/af/af_prod_swarm.py" ]; then
        python3 "$SCRIPT_DIR/af/af_prod_swarm.py" "${args[@]}"
        local exit_code=$?
    else
        echo "Error: Production swarm script not found"
        update_prod_status "$PROD_STATUS_FILE" "prod_swarm" "failed" "Production swarm script not found"
        return 1
    fi
    
    # Update final status
    if [ "$exit_code" -eq 0 ]; then
        update_prod_status "$PROD_STATUS_FILE" "prod_swarm" "completed" "Production swarm completed successfully"
        show_progress_tooltip "$PROGRESS_TOOLTIP" "prod_swarm" "completed" "Production swarm completed successfully"
    else
        update_prod_status "$PROD_STATUS_FILE" "prod_swarm" "failed" "Production swarm failed with exit code $exit_code"
        show_progress_tooltip "$PROGRESS_TOOLTIP" "prod_swarm" "failed" "Production swarm failed with exit code $exit_code"
    fi
    
    return $exit_code
}

