{
  "name": "goalie-enhanced",
  "displayName": "Goalie Enhanced - Automated Governance & Analytics",
  "description": "Advanced VS Code extension with real-time Kanban boards, WSJF-based prioritization, pattern metrics visualization, and batch code-fix application with approval workflows",
  "version": "2.0.0",
  "publisher": "goalie",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Snippets",
    "SCM Providers"
  ],
  "keywords": [
    "kanban",
    "governance",
    "analytics",
    "wsjf",
    "batching",
    "automation",
    "retrospective",
    "metrics",
    "approval",
    "workflow"
  ],
  "activationEvents": [
    "onCommand:goalieKanbanEnhanced.refresh",
    "onCommand:goalieKanbanEnhanced.moveItem",
    "onCommand:goalieKanbanEnhanced.addItem",
    "onCommand:goalieKanbanEnhanced.deleteItem",
    "onCommand:goalieKanbanEnhanced.updateItem",
    "onCommand:patternMetricsEnhanced.refresh",
    "onCommand:batchExecution.show",
    "onCommand:batchExecution.executePlan",
    "onCommand:analyticsDashboard.show",
    "onCommand:analyticsDashboard.refresh",
    "onView:goalieKanbanEnhanced",
    "onView:patternMetricsEnhanced",
    "onView:batchExecution",
    "onView:analyticsDashboard"
  ],
  "main": "./out/extension_enhanced.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "goalieKanbanEnhanced",
          "name": "Goalie Kanban",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "patternMetricsEnhanced",
          "name": "Pattern Metrics",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "goalie-enhanced",
          "title": "Goalie Enhanced",
          "icon": "$(list-ordered)"
        }
      ]
    },
    "views": {
      "goalie-enhanced": [
        {
          "id": "goalieKanbanEnhanced",
          "name": "Kanban Board",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "patternMetricsEnhanced",
          "name": "Pattern Metrics",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "batchExecution",
          "name": "Batch Execution",
          "when": "workspaceFolderCount > 0"
        },
        {
          "id": "analyticsDashboard",
          "name": "Analytics Dashboard",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "commands": [
      {
        "command": "goalieKanbanEnhanced.refresh",
        "title": "Refresh Kanban Board",
        "icon": "$(refresh)"
      },
      {
        "command": "goalieKanbanEnhanced.moveItem",
        "title": "Move Item to Next Stage",
        "icon": "$(arrow-right)"
      },
      {
        "command": "goalieKanbanEnhanced.addItem",
        "title": "Add New Item",
        "icon": "$(add)"
      },
      {
        "command": "goalieKanbanEnhanced.deleteItem",
        "title": "Delete Item",
        "icon": "$(trash)"
      },
      {
        "command": "goalieKanbanEnhanced.updateItem",
        "title": "Update Item",
        "icon": "$(edit)"
      },
      {
        "command": "patternMetricsEnhanced.refresh",
        "title": "Refresh Pattern Metrics",
        "icon": "$(refresh)"
      },
      {
        "command": "batchExecution.show",
        "title": "Show Batch Execution Dashboard",
        "icon": "$(run)"
      },
      {
        "command": "batchExecution.executePlan",
        "title": "Execute Batch Plan",
        "icon": "$(play)"
      },
      {
        "command": "analyticsDashboard.show",
        "title": "Show Analytics Dashboard",
        "icon": "$(graph)"
      },
      {
        "command": "analyticsDashboard.refresh",
        "title": "Refresh Analytics",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "goalieKanbanEnhanced.refresh",
          "when": "view == goalieKanbanEnhanced",
          "group": "navigation"
        },
        {
          "command": "goalieKanbanEnhanced.addItem",
          "when": "view == goalieKanbanEnhanced",
          "group": "navigation"
        },
        {
          "command": "patternMetricsEnhanced.refresh",
          "when": "view == patternMetricsEnhanced",
          "group": "navigation"
        },
        {
          "command": "batchExecution.show",
          "when": "view == batchExecution",
          "group": "navigation"
        },
        {
          "command": "analyticsDashboard.show",
          "when": "view == analyticsDashboard",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "goalieKanbanEnhanced.moveItem",
          "when": "view == goalieKanbanEnhanced && viewItem == kanbanEntry",
          "group": "inline"
        },
        {
          "command": "goalieKanbanEnhanced.updateItem",
          "when": "view == goalieKanbanEnhanced && viewItem == kanbanEntry",
          "group": "inline"
        },
        {
          "command": "goalieKanbanEnhanced.deleteItem",
          "when": "view == goalieKanbanEnhanced && viewItem == kanbanEntry",
          "group": "inline"
        },
        {
          "command": "batchExecution.executePlan",
          "when": "view == batchExecution && viewItem == batchPlan",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Goalie Enhanced",
      "properties": {
        "goalieEnhanced.kanban.wipLimits": {
          "type": "object",
          "default": {
            "NOW": 5,
            "NEXT": 8,
            "LATER": 15
          },
          "description": "Work in Progress limits for each Kanban section",
          "additionalProperties": {
            "type": "number",
            "minimum": 1
          }
        },
        "goalieEnhanced.analytics.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh analytics data"
        },
        "goalieEnhanced.analytics.refreshInterval": {
          "type": "number",
          "default": 30000,
          "description": "Auto-refresh interval in milliseconds",
          "minimum": 5000
        },
        "goalieEnhanced.batching.autoApproveLowRisk": {
          "type": "boolean",
          "default": true,
          "description": "Automatically approve low-risk batch items"
        },
        "goalieEnhanced.batching.riskThreshold": {
          "type": "number",
          "default": 5,
          "description": "Risk level threshold for manual approval (1-10)",
          "minimum": 1,
          "maximum": 10
        },
        "goalieEnhanced.wsjf.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable WSJF-based prioritization"
        },
        "goalieEnhanced.wsjf.weights": {
          "type": "object",
          "default": {
            "userBusinessValue": 1.0,
            "timeCriticality": 1.0,
            "riskReduction": 1.0,
            "jobDuration": 1.0
          },
          "description": "WSJF calculation weights",
          "additionalProperties": {
            "type": "number",
            "minimum": 0.1
          }
        },
        "goalieEnhanced.realtime.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time updates via WebSocket"
        },
        "goalieEnhanced.realtime.socketPath": {
          "type": "string",
          "default": ".goalie/stream.sock",
          "description": "WebSocket socket path for real-time updates"
        }
      }
    },
    "icons": {
      "default": {
        "description": "Default icon",
        "path": {
          "light": "media/goalie-light.svg",
          "dark": "media/goalie-dark.svg"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@types/mocha": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "mocha": "^10.1.0",
    "typescript": "^4.9.4",
    "@vscode/test-electron": "^2.2.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "yaml": "^2.3.4",
    "ws": "^8.16.0",
    "chart.js": "^4.4.2",
    "ed25519": "^0.0.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/goalie/goalie-vscode-enhanced.git"
  },
  "bugs": {
    "url": "https://github.com/goalie/goalie-vscode-enhanced/issues"
  },
  "homepage": "https://github.com/goalie/goalie-vscode-enhanced#readme",
  "license": "MIT",
  "author": "Goalie Team"
}