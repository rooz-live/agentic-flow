{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "../harness/*": ["tests/harness/*"],
      "./harness/*": ["tests/harness/*"]
    }
  },
  "include": ["tests/**/*.ts", "tests/**/*.spec.ts"]
}
